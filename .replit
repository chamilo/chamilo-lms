modules = ["php-8.2", "nodejs-20", "web", "vue-node-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "bash start.sh"]
build = ["sh", "-c", "bash build.sh"]

# ---------------------------------------------------------------------------
# [env] é injetado tanto no build quanto no run no autoscale.
# [userenv.shared] só é injetado no run — NÃO disponível durante o build.
# Por isso PHP_MEMORY_LIMIT e COMPOSER_MEMORY_LIMIT ficam em AMBOS.
# ---------------------------------------------------------------------------
[env]
PHP_MEMORY_LIMIT = "512M"
COMPOSER_MEMORY_LIMIT = "-1"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.production]
APP_INSTALLED = "1"
APP_ENV = "prod"
PHP_MEMORY_LIMIT = "512M"
COMPOSER_MEMORY_LIMIT = "-1"

[userenv.shared]
PHP_MEMORY_LIMIT = "512M"
COMPOSER_MEMORY_LIMIT = "-1"

[[ports]]
localPort = 5000
externalPort = 80

[objectStorage]
defaultBucketID = "replit-objstore-023be920-4f7f-4732-8f41-08729241e402"
