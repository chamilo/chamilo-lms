# .env.example — Chamilo 2.x / Tannus
# Copie para .env e preencha os valores. NUNCA commite o .env com credenciais reais.
# Repositório: github.com/Jabuticabaa/Tannus
#
# Secrets sensíveis (APP_SECRET, JWT_PASSPHRASE) devem ser configurados como
# Replit Secrets (ou variáveis de ambiente do servidor) — não como valores no .env.

###> doctrine/doctrine-bundle ###
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
DATABASE_HOST='localhost'
DATABASE_PORT='3306'
DATABASE_NAME='chamilo'
DATABASE_USER='chamilo'
DATABASE_PASSWORD='<sua_senha_do_banco>'
###< doctrine/doctrine-bundle ###

###> symfony/framework-bundle ###
APP_ENV='dev'
# APP_SECRET: gerar com: php -r "echo bin2hex(random_bytes(32));"
# Configurar como Replit Secret (não inserir valor real aqui)
APP_SECRET='<gerar_com_php_-r_bin2hex_random_bytes_32>'
APP_DEBUG='1'
TRUSTED_PROXIES=127.0.0.1
###< symfony/framework-bundle ###

###> chamilo ###
APP_INSTALLED='1'
APP_ENCRYPT_METHOD='bcrypt'
APP_LOCALE='en_US'
APP_CUSTOM_VUE_TEMPLATE='0'
GOOGLE_MAPS_API_KEY='<sua_chave_google_maps_ou_vazio>'
APP_ENABLE_API_ENTRYPOINT=false
###< chamilo ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
###< nelmio/cors-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
# JWT_PASSPHRASE: gerado automaticamente pelo start.sh via openssl.
# Para produção, configurar como Replit Secret.
JWT_PASSPHRASE='<gerar_com_php_-r_bin2hex_random_bytes_24>'
###< lexik/jwt-authentication-bundle ###

###> chamilo settings ###
DB_MANAGER_ENABLED='0'
SOFTWARE_NAME='Chamilo'
SOFTWARE_URL='https://seu-dominio.replit.app'
DENY_DELETE_USERS='0'
HOSTING_TOTAL_SIZE_LIMIT='0'
THEME_FALLBACK='chamilo'
PACKAGER='chamilo'
DEFAULT_TEMPLATE='default'
ADMIN_CHAMILO_ANNOUNCEMENTS_DISABLE='0'
###< chamilo settings ###

###> mailer ###
# MAILER_DSN=null://null   # desativa e-mails (padrão dev)
# MAILER_DSN=smtp://user:password@smtp.example.com:587
MAILER_DSN=null://null
###< mailer ###

###> azure/aws/gcs storage — descomente e preencha para storage externo ###
# AZURE_STORAGE_CONNECTION_STRING=''
# AWS_S3_STORAGE_VERSION='latest'
# GOOGLE_STORAGE_CLOUD_PROJECT_ID=''
###< storage ###

###> SCIM ###
# SCIM_TOKEN=<token_forte_gerado>
###< SCIM ###
