{% import '@ChamiloCore/Macros/box.html.twig' as display %}

{% autoescape false %}
    {% set exercise_signature_sign_label = 'Sign'|get_plugin_lang('ExerciseSignaturePlugin') %}
    {% if exercise_signature_sign_label is empty %}
        {% set exercise_signature_sign_label = 'Sign'|trans %}
    {% endif %}
    {% set exercise_signature_empty_message = 'ProvideASignatureFirst'|get_plugin_lang('ExerciseSignaturePlugin') %}
    {% if exercise_signature_empty_message is empty %}
        {% set exercise_signature_empty_message = 'Please provide a signature first' %}
    {% endif %}

    <div class="question-result">
        <div class="bg-white border border-gray-25 rounded-lg shadow-sm overflow-hidden">
            <div class="p-6">
                {% if 'editor.save_titles_as_html'|api_get_setting == 'true' %}
                    <div class="prose max-w-none mb-4">{{ data.title|raw }}</div>
                {% else %}
                    <h3 class="text-xl font-semibold text-gray-90 mb-4">{{ data.title }}</h3>
                {% endif %}

                <div class="flex flex-col md:flex-row gap-6">
                    <div class="w-full md:w-1/3 flex-shrink-0 flex flex-col items-center md:items-start space-y-4">
                        <div class="w-24 h-24 rounded-full overflow-hidden border-2 border-primary">
                            <img src="{{ data.avatar }}" alt="{{ data.username }}" class="object-cover w-full h-full">
                        </div>
                        <div class="text-center md:text-left">
                            <p class="font-medium text-gray-90">{{ data.name_url|raw }}</p>
                            <div id="exercise-signature-preview" class="mt-2">
                                {% if signature %}
                                    <img src="{{ signature }}" alt="{{ 'Signature'|trans }}" class="w-32 rounded border border-gray-25 bg-white p-1">
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <div class="w-full md:w-2/3 space-y-4">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="flex items-center space-x-2">
                                {{ 'ToolIcon::MEMBER'|mdi_icon }}
                                <span class="font-semibold">{{ 'Username'|trans }}:</span>
                                <span>{{ data.username }}</span>
                            </div>

                            {% if data.start_date %}
                                <div class="flex items-center space-x-2">
                                    {{ 'ToolIcon::AGENDA'|mdi_icon }}
                                    <span class="font-semibold">{{ 'Start date'|trans }}:</span>
                                    <span>{{ data.start_date }}</span>
                                </div>
                            {% endif %}

                            {% if data.duration %}
                                <div class="flex items-center space-x-2">
                                    {{ 'alarm'|mdi_icon }}
                                    <span class="font-semibold">{{ 'Duration'|trans }}:</span>
                                    <span>{{ data.duration }}</span>
                                </div>
                            {% endif %}

                            {% if data.ip is defined and data.ip %}
                                <div class="flex items-center space-x-2">
                                    {{ 'laptop'|mdi_icon }}
                                    <span class="font-semibold">{{ 'IP'|trans }}:</span>
                                    <span>{{ data.ip }}</span>
                                </div>
                            {% endif %}
                        </div>
                        <div class="flex flex-wrap gap-2 mt-4">
                            {% if allow_signature %}
                                <button id="sign"
                                        type="button"
                                        class="inline-flex min-w-[7rem] items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2 font-semibold text-white shadow-sm transition hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                                    <em class="fas fa-pencil-alt" aria-hidden="true"></em>
                                    <span>{{ exercise_signature_sign_label }}</span>
                                </button>
                            {% endif %}

                            {% if allow_export_pdf %}
                                <a href="{{ export_url }}"
                                   class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-secondary text-secondary hover:bg-secondary hover:text-secondary-button-text transition">
                                    {{ 'ActionIcon::EXPORT_PDF'|mdi_icon_t(24, 'ch-tool-icon', 'Export response report') }}
                                    <span>{{ 'Export response report'|trans }}</span>
                                </a>
                            {% endif %}
                        </div>

                        <hr class="border-gray-20 my-4">
                        <div class="flex items-center space-x-2">
                            {% if data.number_of_answers_saved != data.number_of_answers %}
                                <span class="inline-block px-2 py-1 text-sm font-semibold bg-warning text-warning-button-text rounded">
                {{ '%d / %d answers saved.'|trans|format(data.number_of_answers_saved, data.number_of_answers) }}
              </span>
                            {% else %}
                                <span class="inline-block px-2 py-1 text-sm font-semibold bg-success text-success-button-text rounded">
                {{ '%d / %d answers saved.'|trans|format(data.number_of_answers_saved, data.number_of_answers) }}
              </span>
                            {% endif %}
                        </div>
                        {% if 'exercise.quiz_confirm_saved_answers'|api_get_setting == 'true' %}
                            {% set enable_form = data.track_confirmation.updatedAt is empty and data.track_confirmation.userId == app.user.id %}
                            <form id="quiz_confirm_saved_answers_form" class="space-y-4 mt-4">
                                <label class="flex items-start space-x-2">
                                    <input type="checkbox"
                                           name="quiz_confirm_saved_answers_check"
                                           {% if not enable_form %}disabled{% endif %}
                                            {% if data.track_confirmation.confirmed %}checked{% endif %}
                                           class="form-checkbox h-5 w-5 text-primary">
                                    <span class="text-body-2">{{ 'I accept the number of saved responses in this section.'|trans }}</span>
                                </label>

                                {% if enable_form %}
                                    <p class="text-tiny text-gray-50">
                                        {{ 'If you are not satisfied, do not check the acceptance box and consult the course manager or the platform administrator.'|trans }}
                                    </p>
                                    <div>
                                        <input type="hidden" name="tc_id" value="{{ data.track_confirmation.id }}">
                                        <button type="submit"
                                                class="rounded-lg bg-primary px-4 py-2 font-semibold text-white shadow-sm disabled:opacity-50"
                                                disabled>
                                            <span class="fa fa-save fa-fw"></span>
                                            {{ 'Save'|trans }}
                                        </button>
                                    </div>
                                {% endif %}
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>


    {% if allow_signature %}
        <div id="exercise-signature-modal"
             class="fixed inset-0 z-50 hidden items-center justify-center bg-gray-90/60 p-4">
            <div class="w-full max-w-2xl rounded-lg bg-white shadow-xl border border-gray-25">
                <div class="flex items-center justify-between border-b border-gray-25 px-5 py-4">
                    <h4 class="text-lg font-semibold text-gray-90">
                        {{ exercise_signature_sign_label }}
                    </h4>
                    <button type="button"
                            id="exercise-signature-cancel-x"
                            class="flex h-8 w-8 items-center justify-center rounded-full text-gray-50 hover:bg-danger hover:text-danger-button-text"
                            aria-label="{{ 'Close'|trans }}">
                        ×
                    </button>
                </div>
                <div class="space-y-4 p-5">
                    <p class="text-body-2 text-gray-70">
                        {{ exercise_signature_empty_message }}
                    </p>
                    <div class="rounded-md border border-gray-25 bg-gray-5 p-3">
                        <canvas id="exercise-signature-canvas"
                                class="h-56 w-full rounded bg-white border border-gray-25 touch-none"></canvas>
                    </div>
                    <div id="exercise-signature-message" class="hidden rounded-md px-3 py-2 text-body-2"></div>
                    <div class="flex flex-wrap justify-end gap-2">
                        <button type="button"
                                id="exercise-signature-clear"
                                class="px-4 py-2 rounded-md border border-gray-25 bg-white text-gray-90 hover:bg-gray-10">
                            {{ 'Clear'|trans }}
                        </button>
                        <button type="button"
                                id="exercise-signature-cancel"
                                class="px-4 py-2 rounded-md border border-gray-25 bg-white text-gray-90 hover:bg-gray-10">
                            {{ 'Cancel'|trans }}
                        </button>
                        <button type="button"
                                id="exercise-signature-save"
                                class="rounded-lg bg-primary px-4 py-2 font-semibold text-white shadow-sm transition hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
                            {{ 'Save'|trans }}
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            $(function () {
                var signButton = $('#sign');
                var modal = $('#exercise-signature-modal');
                var canvas = document.getElementById('exercise-signature-canvas');
                var messageBox = $('#exercise-signature-message');
                var saveButton = $('#exercise-signature-save');
                var clearButton = $('#exercise-signature-clear');
                var cancelButtons = $('#exercise-signature-cancel, #exercise-signature-cancel-x');
                var signatureAjaxUrl = {{ (signature_ajax_url|default('/main/inc/ajax/exercise.ajax.php?a=sign_attempt'))|json_encode|raw }};
                var exerciseAttemptId = {{ exe_id|default(data.exe_id|default(0)) }};
                var missingAttemptMessage = {{ 'Exercise attempt was not found.'|trans|json_encode|raw }};
                var emptyMessage = {{ exercise_signature_empty_message|json_encode|raw }};
                var saveErrorMessage = {{ 'An error occurred'|trans|json_encode|raw }};
                var savedMessage = {{ 'Saved.'|trans|json_encode|raw }};

                if (!signButton.length || !canvas) {
                    return;
                }

                var context = canvas.getContext('2d');
                var isDrawing = false;
                var hasSignature = false;
                var lastPoint = null;

                function resizeCanvas() {
                    var ratio = Math.max(window.devicePixelRatio || 1, 1);
                    var width = canvas.offsetWidth || 600;
                    var height = canvas.offsetHeight || 220;

                    canvas.width = width * ratio;
                    canvas.height = height * ratio;
                    context.setTransform(ratio, 0, 0, ratio, 0, 0);
                    context.lineWidth = 2;
                    context.lineCap = 'round';
                    context.lineJoin = 'round';
                    context.strokeStyle = '#111827';
                    clearCanvas();
                }

                function clearCanvas() {
                    var width = canvas.offsetWidth || 600;
                    var height = canvas.offsetHeight || 220;

                    context.clearRect(0, 0, width, height);
                    context.fillStyle = '#ffffff';
                    context.fillRect(0, 0, width, height);
                    hasSignature = false;
                    lastPoint = null;
                }

                function getPoint(event) {
                    var originalEvent = event.originalEvent || event;
                    var source = originalEvent.touches && originalEvent.touches.length
                        ? originalEvent.touches[0]
                        : originalEvent.changedTouches && originalEvent.changedTouches.length
                            ? originalEvent.changedTouches[0]
                            : originalEvent;
                    var rect = canvas.getBoundingClientRect();

                    return {
                        x: source.clientX - rect.left,
                        y: source.clientY - rect.top
                    };
                }

                function startDrawing(event) {
                    event.preventDefault();
                    isDrawing = true;
                    lastPoint = getPoint(event);
                }

                function draw(event) {
                    if (!isDrawing) {
                        return;
                    }

                    event.preventDefault();

                    var point = getPoint(event);
                    context.beginPath();
                    context.moveTo(lastPoint.x, lastPoint.y);
                    context.lineTo(point.x, point.y);
                    context.stroke();
                    lastPoint = point;
                    hasSignature = true;
                }

                function stopDrawing(event) {
                    if (event) {
                        event.preventDefault();
                    }

                    isDrawing = false;
                    lastPoint = null;
                }

                function showMessage(text, type) {
                    var classes = type === 'success'
                        ? 'bg-success text-success-button-text border border-success'
                        : 'bg-danger text-danger-button-text border border-danger';

                    messageBox
                        .removeClass('hidden bg-success text-success-button-text border-success bg-danger text-danger-button-text border-danger')
                        .addClass(classes)
                        .text(text);
                }

                function hideMessage() {
                    messageBox
                        .addClass('hidden')
                        .removeClass('bg-success text-success-button-text border-success bg-danger text-danger-button-text border-danger')
                        .text('');
                }

                function closeModal() {
                    modal.addClass('hidden').removeClass('flex');
                    hideMessage();
                }

                canvas.addEventListener('mousedown', startDrawing);
                canvas.addEventListener('mousemove', draw);
                canvas.addEventListener('mouseup', stopDrawing);
                canvas.addEventListener('mouseleave', stopDrawing);
                canvas.addEventListener('touchstart', startDrawing, { passive: false });
                canvas.addEventListener('touchmove', draw, { passive: false });
                canvas.addEventListener('touchend', stopDrawing, { passive: false });
                canvas.addEventListener('touchcancel', stopDrawing, { passive: false });

                signButton.on('click', function (event) {
                    event.preventDefault();
                    modal.removeClass('hidden').addClass('flex');
                    resizeCanvas();
                });

                clearButton.on('click', function () {
                    clearCanvas();
                    hideMessage();
                });

                cancelButtons.on('click', function () {
                    closeModal();
                });

                saveButton.on('click', function () {
                    if (!hasSignature) {
                        showMessage(emptyMessage, 'error');

                        return;
                    }

                    if (!exerciseAttemptId) {
                        showMessage(missingAttemptMessage, 'error');

                        return;
                    }

                    var signatureData = canvas.toDataURL('image/png');
                    saveButton.prop('disabled', true).addClass('opacity-50');

                    $.post(signatureAjaxUrl, {
                        exe_id: exerciseAttemptId,
                        file: signatureData
                    }).done(function (response) {
                        var cleanResponse = $.trim(response);

                        if (cleanResponse !== '1') {
                            showMessage(cleanResponse && cleanResponse !== '0' ? cleanResponse : saveErrorMessage, 'error');

                            return;
                        }

                        $('#exercise-signature-preview').html(
                            '<img src="' + signatureData + '" alt="Signature" class="w-32 rounded border border-gray-25 bg-white p-1">'
                        );
                        signButton.remove();
                        showMessage(savedMessage, 'success');

                        window.setTimeout(closeModal, 900);
                    }).fail(function () {
                        showMessage(saveErrorMessage, 'error');
                    }).always(function () {
                        saveButton.prop('disabled', false).removeClass('opacity-50');
                    });
                });

                $(window).on('resize', function () {
                    if (!modal.hasClass('hidden')) {
                        resizeCanvas();
                    }
                });
            });
        </script>
    {% endif %}

    {% if 'exercise.quiz_confirm_saved_answers'|api_get_setting == 'true' %}
        {% set enable_form = data.track_confirmation.updatedAt is empty and data.track_confirmation.userId == app.user.id %}
        {% if enable_form %}
            <script>
                $(function () {
                    var form = $('#quiz_confirm_saved_answers_form');
                    var checkbox = form.find('[type="checkbox"]');
                    var button = form.find(':submit');

                    checkbox.on('change', function () {
                        button.prop('disabled', !this.checked);
                    });

                    form.on('submit', function (e) {
                        e.preventDefault();

                        if (!checkbox.is(':checked')) {
                            return;
                        }

                        var xhrData = form.serialize();

                        button.prop('disabled', true);
                        checkbox.prop('disabled', true);

                        $.post(
                            '/main/inc/ajax/exercise.ajax.php?a=quiz_confirm_saved_answers',
                            xhrData
                        ).done(function () {
                            button.parents('.form-group').remove();

                            $('#quiz_end_message').show();
                        }).fail(function (response) {
                            button.replaceWith(response.responseText);
                        });
                    })

                    $('#quiz_end_message').hide();
                });
            </script>
        {% endif %}
    {% endif %}

{% endautoescape %}
