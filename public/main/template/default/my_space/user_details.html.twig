{% import '@ChamiloCore/Macros/box.html.twig' as display %}

{% autoescape false %}
    {% set learner_username = user.username|default('') %}
    {% set learner_display_username = learner_username|length > 25 ? learner_username|slice(0, 24) ~ '…' : learner_username %}
    {% set learner_email = user.email|default('') %}
    {% set learner_display_email = learner_email|length > 25 ? learner_email|slice(0, 24) ~ '…' : learner_email %}

    {% if title is defined %}
        <h2 class="details-title">{{ 'ObjectIcon::COURSE'|mdi_icon(32) }} {{ title }}</h2>
    {% endif %}

    <!-- NO DETAILS -->
    {% if details != true %}
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
            <section class="min-w-0 rounded-lg border border-gray-25 bg-white p-4 shadow-sm">
                <div class="flex flex-col items-center text-center">
                    <img class="mb-4 h-36 w-36 rounded-full" src="{{ user | illustration }}" alt="Avatar">
                    <h3 class="mb-1 max-w-full truncate text-body-1 font-semibold text-gray-90">
                        {{ user.getFullName|e }}
                        (<span title="{{ learner_username|e('html_attr') }}">{{ learner_display_username|e }}</span>)
                    </h3>
                    <p
                        class="max-w-full truncate text-body-2 text-gray-50"
                        title="{{ learner_email|e('html_attr') }}"
                    >
                        {{ learner_display_email|e }}
                    </p>
                </div>
            </section>

            <section class="min-w-0 rounded-lg border border-gray-25 bg-white p-4 shadow-sm">
                <div class="text-body-2 text-gray-90">
                    {{ display.reporting_user_details(user) }}
                </div>

                {% if user_extra.boss_list %}
                    <div class="mt-4 border-t border-gray-25 pt-4">
                        <h3 class="mb-2 text-body-2 font-semibold text-gray-90">{{ 'Student\'s superior'|trans }}</h3>
                        {% for boss in user_extra.boss_list %}
                            <p class="mb-1 text-body-2 text-gray-90">{{ boss }}</p>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>

            <aside class="flex min-w-0 flex-col gap-3">
                {{ display.card_widget('First login in platform'|trans, user_extra.first_connection, 'calendar') }}
                {{ display.card_widget('Latest login in platform'|trans, user_extra.last_connection, 'calendar') }}

                {% if user_extra.legal is defined %}
                    {{ display.card_widget(user_extra.legal.label, user_extra.legal.url_send, 'shield-check-outline') }}
                {% endif %}
                {% if user_extra.certificate is defined %}
                    {{ display.card_widget(user_extra.certificate.label, user_extra.certificate.content, 'certificate-outline') }}
                {% endif %}
            </aside>
        </div>
        <!-- DETAILS -->
    {% else %}
        <div class="details">
            <div class="grid grid-cols-1 gap-4 xl:grid-cols-12">
                <section class="min-w-0 rounded-lg border border-gray-25 bg-white p-4 shadow-sm xl:col-span-3">
                    <div class="flex flex-col items-center text-center">
                        <img
                            class="mb-4 h-36 w-36 rounded-full"
                            src="{{ user | illustration }}"
                            alt="Avatar"
                        >
                        <h3 class="mb-1 max-w-full truncate text-body-1 font-semibold text-gray-90">
                            {{ user.getFullName|e }}
                            (<span title="{{ learner_username|e('html_attr') }}">{{ learner_display_username|e }}</span>)
                        </h3>
                        <p
                            class="max-w-full truncate text-body-2 text-gray-50"
                            title="{{ learner_email|e('html_attr') }}"
                        >
                            {{ learner_display_email|e }}
                        </p>
                    </div>

                    <div class="mt-4 border-t border-gray-25 pt-4 text-body-2 text-gray-90">
                        {{ display.reporting_user_details(user) }}
                    </div>

                    {% if user_extra.boss_list %}
                        <div class="mt-4 border-t border-gray-25 pt-4">
                            <h3 class="mb-2 text-body-2 font-semibold text-gray-90">{{ 'Student\'s superior'|trans }}</h3>
                            {% for boss in user_extra.boss_list %}
                                <p class="mb-1 text-body-2 text-gray-90">{{ boss }}</p>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>

                <section class="flex min-w-0 flex-col gap-4 xl:col-span-6">
                    <div class="rounded-lg border border-gray-25 bg-white p-4 shadow-sm">
                        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                            <div class="flex flex-col items-center text-center">
                                <div
                                    id="easypiechart-blue"
                                    title="{{ 'Progress'|trans }}"
                                    class="easypiechart"
                                    data-percent="{{ user_extra.student_progress }}"
                                >
                                    <span class="percent">{{ user_extra.student_progress }}%</span>
                                </div>
                                <div class="mt-2 max-w-xs text-body-2 text-gray-90">
                                    {{ 'Average progress in courses'|trans }}
                                </div>
                            </div>

                            <div class="flex flex-col items-center text-center">
                                <div
                                    id="easypiechart-red"
                                    title="{{ 'Score'|trans }}"
                                    class="easypiechart"
                                    data-percent="{{ user_extra.student_score }}"
                                >
                                    <span class="percent">{{ user_extra.student_score }} </span>
                                </div>
                                <div class="mt-2 max-w-xs text-body-2 text-gray-90">
                                    {{ 'Average progress in courses'|trans }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-3">
                        <div class="min-w-0 rounded-lg border border-gray-25 bg-white p-3 shadow-sm">
                            <div class="flex items-center gap-3">
                                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-support-2 text-primary">
                                    <i class="mdi mdi-earth text-xl" aria-hidden="true"></i>
                                </span>
                                <div class="min-w-0">
                                    <div class="text-body-1 font-semibold text-gray-90">{{ user_extra.tools.links }}</div>
                                    <div class="truncate text-caption text-gray-50">{{ 'Links accessed'|trans }}</div>
                                </div>
                            </div>
                        </div>

                        <div class="min-w-0 rounded-lg border border-gray-25 bg-white p-3 shadow-sm">
                            <div class="flex items-center gap-3">
                                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-support-2 text-primary">
                                    <i class="mdi mdi-file-document text-xl" aria-hidden="true"></i>
                                </span>
                                <div class="min-w-0">
                                    <div class="text-body-1 font-semibold text-gray-90">{{ user_extra.tools.documents }}</div>
                                    <div class="truncate text-caption text-gray-50">{{ 'Documents'|trans }}</div>
                                </div>
                            </div>
                        </div>

                        <div class="min-w-0 rounded-lg border border-gray-25 bg-white p-3 shadow-sm">
                            <div class="flex items-center gap-3">
                                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-support-2 text-primary">
                                    <i class="mdi mdi-pencil text-xl" aria-hidden="true"></i>
                                </span>
                                <div class="min-w-0">
                                    <div class="text-body-1 font-semibold text-gray-90">{{ user_extra.tools.tasks }}</div>
                                    <div class="truncate text-caption text-gray-50">{{ 'Assignments'|trans }}</div>
                                </div>
                            </div>
                        </div>

                        <div class="min-w-0 rounded-lg border border-gray-25 bg-white p-3 shadow-sm">
                            <div class="flex items-center gap-3">
                                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-support-2 text-primary">
                                    <i class="mdi mdi-message-text text-xl" aria-hidden="true"></i>
                                </span>
                                <div class="min-w-0">
                                    <div class="text-body-1 font-semibold text-gray-90">{{ user_extra.tools.messages }}</div>
                                    <div class="truncate text-caption text-gray-50">{{ 'Number of posts for this user'|trans }}</div>
                                </div>
                            </div>
                        </div>

                        <div class="min-w-0 rounded-lg border border-gray-25 bg-white p-3 shadow-sm">
                            <div class="flex items-center gap-3">
                                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-support-2 text-primary">
                                    <i class="mdi mdi-upload text-xl" aria-hidden="true"></i>
                                </span>
                                <div class="min-w-0">
                                    <div class="text-body-1 font-semibold text-gray-90">{{ user_extra.tools.upload_documents }}</div>
                                    <div class="truncate text-caption text-gray-50">{{ 'Uploaded documents'|trans }}</div>
                                </div>
                            </div>
                        </div>

                        <div class="min-w-0 rounded-lg border border-gray-25 bg-white p-3 shadow-sm">
                            <div class="flex items-center gap-3">
                                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-support-2 text-primary">
                                    <i class="mdi mdi-plug text-xl" aria-hidden="true"></i>
                                </span>
                                <div class="min-w-0">
                                    <div class="truncate text-body-1 font-semibold text-gray-90" title="{{ user_extra.tools.chat_connection|e('html_attr') }}">
                                        {% if user_extra.tools.chat_connection != '' %}
                                            {{ user_extra.tools.chat_connection }}
                                        {% else %}
                                            {{ 'Not Registered'|trans }}
                                        {% endif %}
                                    </div>
                                    <div class="truncate text-caption text-gray-50">{{ 'Latest chat connection'|trans }}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <aside class="flex min-w-0 flex-col gap-3 xl:col-span-3">
                    {{ display.card_widget('First login in platform'|trans, user_extra.first_connection, 'calendar') }}
                    {{ display.card_widget('Latest login in platform'|trans, user_extra.last_connection, 'calendar') }}
                    {% if (user_extra.time_spent_course is defined) %}
                        {{ display.card_widget('Time spent in the course'|trans, user_extra.time_spent_course, 'clock-outline') }}
                    {% endif %}
                    {% if user_extra.legal is defined %}
                        {{ display.card_widget('Legal accepted'|trans, user_extra.legal.datetime, 'gavel', user_extra.legal.icon) }}
                    {% endif %}
                </aside>
            </div>
        </div>
    {% endif %}

    <script>
      $(function() {
        $("#easypiechart-blue").easyPieChart({
          scaleColor: false,
          barColor: "#30a5ff",
          lineWidth: 8,
          trackColor: "#f2f2f2"
        })

        $("#easypiechart-red").easyPieChart({
          scaleColor: false,
          barColor: "#f9243f",
          lineWidth: 8,
          trackColor: "#f2f2f2"
        })
      })
    </script>
{% endautoescape %}
