            function extractProgressLabel($bar, $progressBar, $progressRoot) {
              var rawValues = [];

              // The legacy LP runtime updates the visual width first. Prefer it over
              // the old internal label, otherwise the external label can remain stale.
              var width = $progressBar.get(0) ? $progressBar.get(0).style.width : "";
              if (width) {
                rawValues.push(width);
              }

              rawValues = rawValues.concat([
                $progressBar.attr("aria-valuenow") || "",
                $progressRoot.attr("aria-valuenow") || "",
                $bar.attr("aria-valuenow") || "",
                $progressBar.attr("data-progress-value") || "",
                $progressRoot.attr("data-progress-value") || "",
                $.trim($progressBar.text())
              ]);

              for (var i = 0; i < rawValues.length; i++) {
                var value = $.trim(String(rawValues[i] || ""));
                if (!value) {
                  continue;
                }

                var percentMatch = value.match(/(\d+(?:[\.,]\d+)?)\s*%/);
                if (percentMatch && percentMatch[1]) {
                  return percentMatch[1].replace(",", ".") + "%";
                }

                var numberMatch = value.match(/^(\d+(?:[\.,]\d+)?)$/);
                if (numberMatch && numberMatch[1]) {
                  return numberMatch[1].replace(",", ".") + "%";
                }
              }

              return "0%";
            }

            function normalizeProgressBar() {
              $("#progress_bar").each(function () {
                var $bar = $(this);
                var $progressBar = $bar.find(".progress-bar, .bar, .ui-progressbar-value, .p-progressbar-value").first();
                var $progressRoot = $progressBar.closest(".progress, .p-progressbar, progress").first();

                if (!$progressBar.length) {
                  return;
                }

                if (!$progressRoot.length) {
                  $progressRoot = $bar;
                }

                var label = extractProgressLabel($bar, $progressBar, $progressRoot);

                $bar.contents().filter(function () {
                  return this.nodeType === 3;
                }).remove();

                $bar.find(".progress, .p-progressbar, progress").contents().filter(function () {
                  return this.nodeType === 3;
                }).remove();

                $bar.find(".progress-bar, .bar, .ui-progressbar-value, .p-progressbar-value").each(function () {
                  var $inner = $(this);
                  $inner.attr("aria-label", label + " " + lpCompletedText);
                  $inner.find(".p-progressbar-label").remove();
                  $inner.contents().filter(function () {
                    return this.nodeType === 3;
                  }).remove();
                });

                var $label = $bar.find(".lp-progress-label").first();
                if (!$label.length) {
                  $label = $('<div class="lp-progress-label"></div>').appendTo($bar);
                }

                $label.text(label + " " + lpCompletedText);
              });
            }

