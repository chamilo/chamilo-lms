<div class="space-y-6">
    <section class="rounded-2xl border border-gray-25 bg-white p-6 shadow-sm">
        <div class="mb-6 flex flex-col gap-2">
            <div class="flex items-center gap-3">
                <span class="mdi mdi-certificate ch-tool-icon text-primary" aria-hidden="true"></span>
                <h2 class="text-xl font-semibold text-gray-90">
                    {{ 'Search certificates'|get_lang }}
                </h2>
            </div>
            <p class="text-body-2 text-gray-50">
                {{ 'Search users by first name and last name to view their available certificates.'|get_lang }}
            </p>
        </div>

        <form
                method="get"
                action="{{ search_url }}"
                class="grid grid-cols-1 gap-4 md:grid-cols-[1fr_1fr_auto]"
        >
            <div class="flex flex-col gap-2">
                <label for="firstname" class="text-body-2 font-medium text-gray-90">
                    {{ 'First name'|get_lang }}
                </label>
                <input
                        id="firstname"
                        name="firstname"
                        type="text"
                        value="{{ firstname }}"
                        class="w-full rounded-lg border border-gray-25 bg-white px-3 py-2 text-body-2 text-gray-90 shadow-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20"
                        autocomplete="given-name"
                >
            </div>

            <div class="flex flex-col gap-2">
                <label for="lastname" class="text-body-2 font-medium text-gray-90">
                    {{ 'Last name'|get_lang }}
                </label>
                <input
                        id="lastname"
                        name="lastname"
                        type="text"
                        value="{{ lastname }}"
                        class="w-full rounded-lg border border-gray-25 bg-white px-3 py-2 text-body-2 text-gray-90 shadow-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20"
                        autocomplete="family-name"
                >
            </div>

            <div class="flex items-end">
                <button type="submit" class="btn btn--primary w-full md:w-auto">
                    <span class="mdi mdi-magnify ch-tool-icon" aria-hidden="true"></span>
                    {{ 'Search'|get_lang }}
                </button>
            </div>
        </form>
    </section>

    {% if warning_message is not empty %}
        <div class="flex items-start gap-3 rounded-2xl border border-warning/30 bg-warning/10 p-4 text-body-2 text-gray-90">
            <span class="mdi mdi-alert ch-tool-icon text-warning" aria-hidden="true"></span>
            <div>
                {{ warning_message }}
            </div>
        </div>
    {% endif %}

    {% if user_list is not empty %}
        <section class="overflow-hidden rounded-2xl border border-gray-25 bg-white shadow-sm">
            <div class="flex items-center gap-3 border-b border-gray-20 bg-support-2 px-6 py-4">
                <span class="mdi mdi-account-multiple ch-tool-icon text-primary" aria-hidden="true"></span>
                <h3 class="text-lg font-semibold text-gray-90">
                    {{ 'Search results'|get_lang }}
                </h3>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-20 text-body-2">
                    <thead class="bg-gray-10">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left font-semibold text-gray-90">
                            {{ 'First name'|get_lang }}
                        </th>
                        <th scope="col" class="px-6 py-3 text-left font-semibold text-gray-90">
                            {{ 'Last name'|get_lang }}
                        </th>
                        <th scope="col" class="px-6 py-3 text-right font-semibold text-gray-90">
                            &nbsp;
                        </th>
                    </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-20 bg-white">
                    {% for user in user_list %}
                        <tr class="transition hover:bg-support-2">
                            <td class="px-6 py-4 text-gray-90">
                                {{ user.firstname }}
                            </td>
                            <td class="px-6 py-4 text-gray-90">
                                {{ user.lastname }}
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a
                                        href="{{ _p.web_main }}gradebook/search.php?id={{ user.id }}"
                                        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-gray-25 bg-white text-primary shadow-sm transition hover:bg-support-1 hover:text-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                                        title="{{ 'Certificates'|get_lang }}"
                                        aria-label="{{ 'Certificates'|get_lang }}"
                                >
                                    <span class="mdi mdi-certificate ch-tool-icon" aria-hidden="true"></span>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% endif %}

    {% if course_list is not empty or session_list is not empty %}
        <section class="rounded-2xl border border-gray-25 bg-white p-6 shadow-sm">
            <div class="flex items-start gap-3">
                <span class="mdi mdi-account ch-tool-icon text-primary" aria-hidden="true"></span>
                <div class="flex flex-col gap-1">
                    <h2 class="text-xl font-semibold text-gray-90">
                        {{ user_info.complete_name }}
                    </h2>
                    <p class="text-body-2 text-gray-50">
                        {{ 'Certificates'|get_lang }}
                    </p>
                </div>
            </div>
        </section>

        {% if course_list is not empty %}
            <section class="overflow-hidden rounded-2xl border border-gray-25 bg-white shadow-sm">
                <div class="flex items-center gap-3 border-b border-gray-20 bg-support-2 px-6 py-4">
                    <span class="mdi mdi-book-open-page-variant ch-tool-icon text-primary" aria-hidden="true"></span>
                    <h3 class="text-lg font-semibold text-gray-90">
                        {{ 'Courses'|get_lang }}
                    </h3>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-20 text-body-2">
                        <thead class="bg-gray-10">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left font-semibold text-gray-90">
                                {{ 'Course'|get_lang }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-right font-semibold text-gray-90">
                                {{ 'Score'|get_lang }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-center font-semibold text-gray-90">
                                {{ 'Date'|get_lang }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-right font-semibold text-gray-90">
                                &nbsp;
                            </th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-20 bg-white">
                        {% for row in course_list %}
                            <tr class="transition hover:bg-support-2">
                                <td class="px-6 py-4 text-gray-90">
                                    {{ row.course }}
                                </td>
                                <td class="px-6 py-4 text-right text-gray-90">
                                    {{ row.score }}
                                </td>
                                <td class="px-6 py-4 text-center text-gray-50">
                                    {{ row.date }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a
                                            href="{{ row.link }}"
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="btn btn--plain"
                                    >
                                        <span class="mdi mdi-certificate ch-tool-icon" aria-hidden="true"></span>
                                        {{ 'Certificate'|get_lang }}
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        {% endif %}

        {% if session_list is not empty %}
            <section class="overflow-hidden rounded-2xl border border-gray-25 bg-white shadow-sm">
                <div class="flex items-center gap-3 border-b border-gray-20 bg-support-2 px-6 py-4">
                    <span class="mdi mdi-google-classroom ch-tool-icon text-primary" aria-hidden="true"></span>
                    <h3 class="text-lg font-semibold text-gray-90">
                        {{ 'Course sessions'|get_lang }}
                    </h3>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-20 text-body-2">
                        <thead class="bg-gray-10">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left font-semibold text-gray-90">
                                {{ 'Session'|get_lang }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-left font-semibold text-gray-90">
                                {{ 'Course'|get_lang }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-right font-semibold text-gray-90">
                                {{ 'Score'|get_lang }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-center font-semibold text-gray-90">
                                {{ 'Date'|get_lang }}
                            </th>
                            <th scope="col" class="px-6 py-3 text-right font-semibold text-gray-90">
                                &nbsp;
                            </th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-20 bg-white">
                        {% for row in session_list %}
                            <tr class="transition hover:bg-support-2">
                                <td class="px-6 py-4 text-gray-90">
                                    {{ row.session }}
                                </td>
                                <td class="px-6 py-4 text-gray-90">
                                    {{ row.course }}
                                </td>
                                <td class="px-6 py-4 text-right text-gray-90">
                                    {{ row.score }}
                                </td>
                                <td class="px-6 py-4 text-center text-gray-50">
                                    {{ row.date }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a
                                            href="{{ row.link }}"
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="btn btn--plain"
                                    >
                                        <span class="mdi mdi-certificate ch-tool-icon" aria-hidden="true"></span>
                                        {{ 'Certificate'|get_lang }}
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        {% endif %}
    {% endif %}
</div>
