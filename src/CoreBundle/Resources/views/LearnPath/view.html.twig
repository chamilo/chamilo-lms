              if (patched) return patched;

              var href = $el.attr("href") || "";
              if (isRealHref(href)) return href;

              var onclickValue = $el.attr("onclick") || "";
              return extractUrlFromOnclick(onclickValue);
            }

            function getNumeric(v) {
