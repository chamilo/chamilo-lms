{% import 'StudentFollowUp/view/post.html.twig' as template %}

<section class="space-y-6">
    <header class="rounded-2xl border border-gray-25 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-primary">
                    {{ 'plugin_title'|get_plugin_lang('StudentFollowUpPlugin') }}
                </p>
                <h2 class="text-2xl font-semibold text-gray-90">
                    {{ 'FollowUpTimeline'|get_plugin_lang('StudentFollowUpPlugin') }}
                </h2>
                <p class="mt-1 text-sm text-gray-50">
                    {{ student_info.complete_name }}
                </p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                {% if can_create_post %}
                    <a class="btn btn--primary inline-flex items-center gap-2" href="{{ create_post_url }}">
                        <span class="mdi mdi-plus-box" aria-hidden="true"></span>
                        {{ 'AddFollowUpNote'|get_plugin_lang('StudentFollowUpPlugin') }}
                    </a>
                {% endif %}
                <a class="btn btn--plain inline-flex items-center gap-2" href="{{ my_students_url }}">
                    <span class="mdi mdi-arrow-left" aria-hidden="true"></span>
                    {{ 'BackToStudents'|get_plugin_lang('StudentFollowUpPlugin') }}
                </a>
            </div>
        </div>
    </header>

    {% if posts|length %}
        <div class="space-y-4">
            {% for post in posts %}
                {{ template.post_template('simple', post, information_icon, post_url, current_url, []) }}
            {% endfor %}
        </div>

        {% if pagination %}
            <div class="rounded-2xl border border-gray-25 bg-white p-4 shadow-sm">
                {{ pagination|raw }}
            </div>
        {% endif %}
    {% else %}
        <div class="rounded-2xl border border-gray-25 bg-white p-6 text-center shadow-sm">
            <span class="mdi mdi-clipboard-text-off-outline ch-tool-icon-gradient text-5xl" aria-hidden="true"></span>
            <h3 class="mt-3 text-lg font-semibold text-gray-90">
                {{ 'NoFollowUpPosts'|get_plugin_lang('StudentFollowUpPlugin') }}
            </h3>
            <p class="mt-1 text-sm text-gray-50">
                {{ 'NoFollowUpPostsHelp'|get_plugin_lang('StudentFollowUpPlugin') }}
            </p>

            {% if can_create_post %}
                <div class="mt-4">
                    <a class="btn btn--primary inline-flex items-center gap-2" href="{{ create_post_url }}">
                        <span class="mdi mdi-plus-box" aria-hidden="true"></span>
                        {{ 'AddFollowUpNote'|get_plugin_lang('StudentFollowUpPlugin') }}
                    </a>
                </div>
            {% endif %}
        </div>
    {% endif %}
</section>
