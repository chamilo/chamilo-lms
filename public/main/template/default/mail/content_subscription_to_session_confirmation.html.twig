<p>{{ 'Dear'|get_lang }} {{ complete_name }},</p>
{% if show_username is defined and show_username and username is not empty %}
    <p>
        <strong>{{ username_label|e }}</strong>:
        {{ username|e }}
    </p>
{% endif %}

{% if show_lost_password_link is defined and show_lost_password_link %}
    <p>
        <a href="{{ lost_password_url|e('html_attr') }}">
            {{ lost_password_link_label|e }}
        </a>
    </p>
{% endif %}
<p>{{ 'You are registered to session: %s.'|get_lang|format(session_name) }}</p>
<p>{{ 'The address of'|get_lang }}  {{ _s.site_name }} {{ 'is'|get_lang }} : {{ url('index') }}</p>
<p>{{ 'In case of trouble, contact us.'|get_lang }}</p>
<p>{{ 'Sincerely'|get_lang }}</p>
