<div class="w-full px-4 py-4">
    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6 items-start">
        <aside class="xl:col-span-3">
            <div class="rounded-2xl border border-gray-20 bg-white shadow-sm">
                <div class="p-4 space-y-4">
                    <div>
                        <h1 class="text-xl font-semibold text-gray-900">
                            {{ tool.title }}
                        </h1>

                        {% if tool.description %}
                            <p class="mt-2 text-sm text-gray-600">
                                {{ tool.description }}
                            </p>
                        {% endif %}
                    </div>

                    <div class="border-t border-gray-10 pt-4">
                        <div class="mb-3 text-sm font-semibold text-gray-800">
                            {{ 'Content'|trans }}
                        </div>

                        <div class="space-y-2">
                            {{ toc_html|raw }}
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <section class="xl:col-span-9">
            <div class="rounded-2xl border border-gray-20 bg-white shadow-sm overflow-hidden">
                <div class="flex items-center justify-between border-b border-gray-10 px-4 py-3">
                    <div>
                        <h2 class="text-sm font-semibold text-gray-800">
                            {{ 'Preview'|trans }}
                        </h2>
                        <p class="text-xs text-gray-500">
                            {{ 'The selected activity will open here.'|trans }}
                        </p>
                    </div>
                </div>

                <div class="p-2">
                    <iframe
                            id="ifr-content"
                            name="ifr_content"
                            src="{{ initial_launch_url }}"
                            class="block h-screen w-full rounded-xl bg-white"
                            allowfullscreen
                    ></iframe>
                </div>
            </div>
        </section>
    </div>
</div>
