            function syncCollapsedIframeBoundary() {
              var $rightZone = $("#learning_path_right_zone");
              var $leftZone = $("#learning_path_left_zone");
              var $toggle = $("#lp-view-expand-toggle");
              var $iframe = getLpIframe();
              var isCollapsed = $main.hasClass("lp-view-collapsed");

              if ($rightZone.length) {
                if (isCollapsed) {
                  var railWidth = 64;
                  var contentGap = 34;
                  var contentLeft = railWidth + contentGap;

                  try {
                    if ($leftZone.length) {
                      var leftRect = $leftZone.get(0).getBoundingClientRect();
                      if (leftRect && leftRect.right) {
                        contentLeft = Math.max(contentLeft, Math.ceil(leftRect.right + contentGap));
                      }
                    }

                    if ($toggle.length) {
                      var toggleRect = $toggle.get(0).getBoundingClientRect();
                      if (toggleRect && toggleRect.right) {
                        contentLeft = Math.max(contentLeft, Math.ceil(toggleRect.right + 16));
                      }
                    }
                  } catch (e) {
                    contentLeft = railWidth + contentGap;
                  }

                  // Keep the right content strictly after the collapsed rail/arrow.
                  // The clamp avoids oversized offsets if a browser reports a transient
                  // animation rectangle during the collapse transition.
                  contentLeft = Math.max(82, Math.min(contentLeft, 180));

                  $main.get(0).style.setProperty("--lp-collapsed-content-left", contentLeft + "px");

                  $rightZone.get(0).style.setProperty("position", "fixed", "important");
                  $rightZone.get(0).style.setProperty("top", "0", "important");
                  $rightZone.get(0).style.setProperty("right", "0", "important");
                  $rightZone.get(0).style.setProperty("bottom", "0", "important");
                  $rightZone.get(0).style.setProperty("left", contentLeft + "px", "important");
                  $rightZone.get(0).style.setProperty("width", "auto", "important");
                  $rightZone.get(0).style.setProperty("max-width", "calc(100vw - " + contentLeft + "px)", "important");
                  $rightZone.get(0).style.setProperty("margin-left", "0", "important");
                  $rightZone.get(0).style.setProperty("padding-left", "30px", "important");
                  $rightZone.get(0).style.setProperty("box-sizing", "border-box", "important");
                  $rightZone.get(0).style.setProperty("overflow", "hidden", "important");
                } else {
                  $rightZone.get(0).style.removeProperty("position");
                  $rightZone.get(0).style.removeProperty("top");
                  $rightZone.get(0).style.removeProperty("right");
                  $rightZone.get(0).style.removeProperty("bottom");
                  $rightZone.get(0).style.removeProperty("left");
                  $rightZone.get(0).style.removeProperty("width");
                  $rightZone.get(0).style.removeProperty("max-width");
                  $rightZone.get(0).style.removeProperty("margin-left");
                  $rightZone.get(0).style.removeProperty("padding-left");
                  $rightZone.get(0).style.removeProperty("box-sizing");
                  $rightZone.get(0).style.removeProperty("overflow");
                }
              }

              if (!$iframe.length) {
                return;
              }

              // Keep the iframe itself inside the visible content area.
              $iframe.css({
                position: "relative",
                left: "auto",
                right: "auto",
                top: "auto",
                width: "100%",
                maxWidth: "100%",
                minWidth: "0",
                height: "100%",
                maxHeight: "100%",
                marginLeft: "0",
                paddingLeft: "0",
                boxSizing: "border-box",
                transform: "none"
              });

              // Same-origin LP documents can receive an internal safety padding.
              // Some legacy LP item pages render their content from x=0 inside the iframe,
              // so parent spacing alone is not enough when the TOC is collapsed.
              try {
                var iframe = $iframe.get(0);
                var doc = iframe && (iframe.contentDocument || iframe.contentWindow.document);
                if (!doc || !doc.head) {
                  return;
                }

                var styleId = "lp-modern-collapsed-boundary-style";
                var style = doc.getElementById(styleId);

                if (isCollapsed) {
                  if (!style) {
                    style = doc.createElement("style");
                    style.id = styleId;
                    doc.head.appendChild(style);
                  }
                  style.textContent = [
                    "html, body {",
                    "  box-sizing: border-box !important;",
                    "  overflow-x: hidden !important;",
                    "}",
                    "body {",
                    "  margin-left: 0 !important;",
                    "  padding-left: 0 !important;",
                    "  padding-right: 18px !important;",
                    "}",
                    "#main_content, .container, .container-fluid, .lp_item_content, .document-view, .exercise-overview {",
                    "  box-sizing: border-box !important;",
                    "  max-width: 100% !important;",
                    "}"
                  ].join("\n");
                } else if (style) {
                  style.parentNode.removeChild(style);
                }
              } catch (e) {
                // Cross-origin embeds such as external videos cannot be adjusted.
              }
            }

