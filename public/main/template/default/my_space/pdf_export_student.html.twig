<h1 style="color:#000000; background-color:#fff; font-size:22px; text-align:center; font-weight:bold; padding:5px 10px;">
    {{ title|default('') }}
</h1>

{% if session_title is defined and session_title is not empty %}
    <h1 style="color:#ffffff; background-color:#084B8A; font-size:22px; text-align:center; font-weight:bold; padding:5px 10px;">
        {{ session_title }}
    </h1>
{% endif %}

{% if student is defined and student is not empty %}
    <div style="font-weight:bold; padding-bottom:20px;">
        {{ student }}
    </div>
{% endif %}

{% if table_progress is defined and table_progress is not empty %}
    <div style="background:#f1f6ff;">
        {{ table_progress|raw }}
    </div>
{% endif %}

{% if subtitle is defined and subtitle is not empty %}
    <div style="padding-bottom:20px; margin-top:20px;">
        {{ subtitle|raw }}
    </div>
{% endif %}

{% if table_course is defined and table_course is not empty %}
    <div style="background:#f1f6ff;">
        {{ table_course|raw }}
    </div>
{% endif %}
