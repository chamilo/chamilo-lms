{% autoescape false %}
    <div class="app-elevator">
        <button id="back-to-top"
                role="button" type="button"
                class="btn btn--primary"
                title="{{ 'Back to top'|trans }}" data-toggle="tooltip" data-placement="left">
            <i class="fas fa-angle-up"></i>
        </button>
    </div>

    {% set institution_address = chamilo_settings_get('platform.institution_address')|default('')|trim %}

    <footer class="app-footer">
        <div>
            <a href="{{ url('index')}}" target="_blank">
                {{ "Chamilo"|trans }}
            </a>&copy; {{ "now"|date("Y") }}
        </div>

        {% if institution_address %}
            <div class="app-footer__institution-address">
                {{ institution_address|e }}
            </div>
        {% endif %}

        <div class="ml-auto">
            {% if administrator_name is defined %}
                {{ administrator_name }}
            {% endif %}
        </div>
    </footer>

    {# Delete modal #}
    <div class="modal fade" id="confirm-delete" tabindex="-1" role="dialog" aria-labelledby="confirm-delete-title" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                    <h4 class="modal-title" id="myModalLabel">{{ 'Delete'|trans }}</h4>
                </div>

                <div class="modal-body">
                    <p class="debug-url"></p>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn--plain" data-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    <a id="delete_item" class="btn btn--danger btn-ok">{{ 'Delete'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
{% endautoescape %}

{{ execution_stats }}

{# Backward-compatible footer extra content (if provided by legacy controllers/layouts). #}
{% if footer_extra_content is defined and footer_extra_content|default('')|trim %}
    {{ footer_extra_content|raw }}
{% endif %}
