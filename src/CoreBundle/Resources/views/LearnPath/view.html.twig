            function collectTocItemIds() {
              var ids = [];
              var seen = {};

              $("#toc_id [id^='toc_']").each(function () {
                var raw = (this.id || "").replace("toc_", "");
                var n = parseInt(raw, 10);
                if (!Number.isFinite(n) || n <= 0) return;
                if (seen[n]) return;
                seen[n] = true;
                ids.push(n);
              });

              if (!ids.length) {
                $("#toc_id a[href*='item_id=']").each(function () {
                  try {
                    var href = $(this).attr("href") || "";
                    var m = href.match(/[?&]item_id=(\d+)/);
                    if (!m) return;
                    var n = parseInt(m[1], 10);
                    if (!Number.isFinite(n) || n <= 0) return;
                    if (seen[n]) return;
                    seen[n] = true;
                    ids.push(n);
                  } catch (e) {}
                });
              }

              return ids;
            }

            function getCurrentItemIdSafe() {
              // Prefer runtime value (most reliable when available)
              try {
                if (window.olms && typeof olms.lms_item_id !== "undefined") {
                  var n = parseInt(olms.lms_item_id, 10);
                  if (Number.isFinite(n) && n > 0) return n;
                }
              } catch (e) {}

              var fromWindow = getNumeric(window.lpCurrentItemId);
              if (fromWindow > 0) return fromWindow;

              var fromUrl = parseInt(getSearchParam("item_id"), 10);
              return Number.isFinite(fromUrl) ? fromUrl : 0;
            }

            function resolveDirectionToId(direction, currentId) {
              var ids = collectTocItemIds();
              if (!ids.length) {
                return 0;
              }

              var idx = ids.indexOf(currentId);
              if (idx === -1) {
                return direction === "next" ? (ids[0] || 0) : 0;
              }

              if (direction === "next") {
                return ids[idx + 1] || 0;
              }
              if (direction === "previous") {
                return ids[idx - 1] || 0;
              }
              return 0;
            }

