{% autoescape false %}
    {% macro itemIcon(type) %}
        {% set normalizedType = type|default('document')|lower|replace({' ': '_'}) %}
        {% set icon = 'file-document-outline' %}

        {% if normalizedType in ['dir', 'chapter', 'section'] %}
            {% set icon = 'bookmark' %}
        {% elseif normalizedType in ['quiz', 'exercise', 'test'] %}
            {% set icon = 'clipboard-text-outline' %}
        {% elseif normalizedType in ['student_publication', 'assignment', 'work', 'homework'] %}
            {% set icon = 'file-upload-outline' %}
        {% elseif normalizedType in ['forum', 'thread'] %}
            {% set icon = 'forum-outline' %}
        {% elseif normalizedType in ['link'] %}
            {% set icon = 'link-variant' %}
        {% elseif normalizedType in ['video'] %}
            {% set icon = 'video-outline' %}
        {% elseif normalizedType in ['audio'] %}
            {% set icon = 'volume-high' %}
        {% elseif normalizedType in ['certificate'] %}
            {% set icon = 'star-outline' %}
        {% elseif normalizedType in ['sco', 'scorm', 'xapi'] %}
            {% set icon = 'cube-outline' %}
        {% elseif normalizedType in ['h5p'] %}
            {% set icon = 'puzzle-outline' %}
        {% elseif normalizedType in ['survey'] %}
            {% set icon = 'poll' %}
        {% endif %}

        <span class="lp-item-type-icon" aria-hidden="true">
            <i class="mdi mdi-{{ icon }}"></i>
        </span>
    {% endmacro %}

    {% macro statusIcon(statusClass) %}
        {% set icon = 'circle-outline' %}
        {% if statusClass == 'scorm_completed' %}
            {% set icon = 'check-circle' %}
        {% elseif statusClass == 'scorm_failed' %}
            {% set icon = 'close-circle' %}
        {% endif %}

        <span class="lp-item-status-icon" aria-hidden="true">
            <i class="mdi mdi-{{ icon }}"></i>
        </span>
    {% endmacro %}

    {% macro processItem(item, lp_current_item_id, status_list) %}
        {% import _self as self %}
        {% set itemClass = ' ' %}
        {% if 'dir' == item.itemType %}
            {% set itemClass = itemClass ~ 'scorm_item_section ' %}
        {% endif %}

        {% if lp_current_item_id == item.iid %}
            {% set itemClass = itemClass ~ 'scorm_highlight ' %}
        {% endif %}

        {% set itemLevel = 'level_' ~ (item.lvl - 1) %}
        {% set itemStatusClass = status_list[item.iid]|default('') %}
        {% set accordionClass = item.itemType == 'dir' and 'true' == chamilo_settings_get('lp.lp_view_accordion') ? 'accordion' : '' %}
        <div id="toc_{{ item.iid }}"
             class="scorm_item_normal {{ itemStatusClass }} {{ itemClass }} item-{{ item.itemType }} {{ accordionClass }}">
            {% if item.itemType == 'dir' %}
                <div class="section {{ itemLevel }}" title="{{ item.description | striptags | e('html') }}">
                    <div class="lp-section-row">
                        <span class="lp-item-main">
                            {{ self.itemIcon(item.itemType) }}
                            <span class="lp-item-title">{{ item.title | raw }}</span>
                        </span>
                        <span class="lp-item-status-icon lp-section-chevron" aria-hidden="true">
                            <i class="mdi mdi-chevron-up"></i>
                        </span>
                    </div>
                </div>
            {% else %}
                <div class="item {{ itemLevel }}" title="{{ item.description | striptags | e('html') }}">
                    <a name="atoc_{{ item.iid }}"></a>
                    <a data-type="type-{{ item.itemType }}" class="items-list lp-item-row" href="#"
                       onclick="switch_item('{{ lp_current_item_id }}','{{ item.iid }}'); return false;">
                        <span class="lp-item-main">
                            {{ self.itemIcon(item.itemType) }}
                            <span class="lp-item-title">{{ item.title | raw }}</span>
                        </span>
                        {{ self.statusIcon(itemStatusClass) }}
                    </a>
                </div>
            {% endif %}
        </div>

        {% if item.itemType == 'dir' %}
            {% if item.__children|length %}
                <div class="item-children">
                    {% for child in item.__children %}
                        {{ self.processItem(child, lp_current_item_id, status_list) }}
                    {% endfor %}
                </div>
            {% endif %}
        {% endif %}
    {% endmacro %}

    {% if data_list is not empty %}
        <div id="learning_path_toc" class="scorm-list">
            <div class="scorm-body">
                <div class="lp-toc-title">{{ lp_title_scorm|default("Lesson name"|trans)|striptags }}</div>
                <div id="inner_lp_toc" class="inner_lp_toc scrollbar-light">
                    {% from _self import processItem %}
                    {% for item in data_list %}
                        {{ processItem(item, lp_current_item_id, status_list) }}
                    {% endfor %}
                </div>
            </div>
        </div>
    {% else %}
        <div id="learning_path_toc" class="scorm-list">
            <div class="scorm-body">
                <div class="lp-toc-title">{{ lp_title_scorm|default("Lesson name"|trans)|striptags }}</div>
                <div class="lp-empty-state">
                <span class="lp-empty-state-icon" aria-hidden="true">
                    <i class="mdi mdi-book-open-page-variant-outline"></i>
                </span>
                <div class="lp-empty-state-title">{{ "No learning path content yet"|trans }}</div>
                <div class="lp-empty-state-text">{{ "Add a course introduction or add documents to display them to learners."|trans }}</div>
                </div>
            </div>
        </div>
    {% endif %}

    {% if data_panel is not empty %}
        <div id="learning_path_toc">
            <div class="scorm-title">
                <h4>{{ lp_title_scorm }}</h4>
            </div>

            {% macro tree(item) %}
                {% import _self as self %}
                {% set isCurrentItem = item.id == lp_current_item_id %}
                {% set itemStatusClass = item.status_css_class_name|default('') %}
                <div id="toc_{{ item.id }}"
                     class="panel panel-default
                        {{ item.parent_id ? 'child_item':'root_item' }}
                        lp_item_type_{{ item.type|replace({' ': '_'}) }}
                        {{ itemStatusClass }}
                        {{ item.is_current ? 'current_item scorm_highlight' : '' }}
                        {{ item.is_parent_of_current ? 'parent_of_current_item' : '' }}
                        {{ item.is_chapter ? 'chapter' : '' }}
                     "
                     data-lp-id="{{ item.id }}">
                    <div class="status-heading">
                        <div id="heading_item_{{ item.id }}" class="panel-heading" role="tab">
                            {% if item.children|length %}
                                <a class="item-header lp-section-row" role="button"
                                   data-toggle="collapse" data-parent="#tocchildren_{{ item.parent_id }}"
                                   href="#tocchildren_{{ item.id }}"
                                   aria-expanded="{{ isCurrentItem ? 'true' : 'false' }}"
                                   aria-controls="tocchildren_{{ item.id }}">
                                    <span class="lp-item-main">
                                        {{ self.itemIcon(item.type|default('dir')) }}
                                        <span class="lp-item-title">{{ item.title | raw }}</span>
                                    </span>
                                    <span class="lp-item-status-icon" aria-hidden="true">
                                        <i class="mdi mdi-chevron-down"></i>
                                    </span>
                                </a>
                            {% else %}
                                <a data-type="type-{{ item.type }}" class="item-action lp-item-row" href="#"
                                   onclick="switch_item('{{ item.current_id }}','{{ item.id }}'); return false;">
                                    <span class="lp-item-main">
                                        {{ self.itemIcon(item.type) }}
                                        <span class="lp-item-title">{{ item.title | raw }}</span>
                                    </span>
                                    {{ self.statusIcon(itemStatusClass) }}
                                </a>
                            {% endif %}
                        </div>
                    </div>
                    {% if item.children|length %}
                        <div id="tocchildren_{{ item.id }}"
                             class="panel-collapse collapse {{ isCurrentItem ? 'in' : '' }}"
                             role="tabpanel"
                             aria-labelledby="heading_item_{{ item.id }}">
                            <div class="panel-body">
                                {% for child in item.children %}
                                    {{ self.tree(child) }}
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            {% endmacro %}

            {% from _self import tree %}
            <div id="tocchildren_" class="panel-group" role="tablist" aria-multiselectable="true">
                {% for item in data_panel %}
                    {{ tree(item) }}
                {% endfor %}
            </div>
        </div>
    {% endif %}
{% endautoescape %}
