{% extends '@ChamiloCore/Layout/no_layout.html.twig' %}

{% set lp_view = true %}

{% block content %}
    {% set toc_hidden = (toc_hidden|default(0) + 0) %}
    {% set show_left_column = (show_left_column|default(1) + 0) %}
    {% set lp_id_num = (lp_id|default(0) + 0) %}
    {% set lp_current_item_id_num = (lp_current_item_id|default(0) + 0) %}
    {% set is_lti_embeddable = (is_lti_embeddable|default(0) + 0) %}
    {% set render_left_zone = (show_left_column == 1) or (toc_hidden == 1) %}
    <script>
      window.lpId = {{ lp_id_num }};
      window.lpCurrentItemId = {{ lp_current_item_id_num }};
      window.isLtiEmbeddable = {{ is_lti_embeddable }};
      window.lpAiLearningHelper = {
        enabled: {{ ai_learning_helper_enabled|default(0) + 0 }},
        endpoint: {{ ai_learning_helper_endpoint|default('')|json_encode|raw }},
        language: {{ ai_learning_helper_language|default('en')|json_encode|raw }},
        cid: {{ ai_learning_helper_course_id|default(0) + 0 }},
        sid: {{ ai_learning_helper_session_id|default(0) + 0 }},
        lpItemId: {{ lp_current_item_id_num }}
      };
    </script>
    {# Build iframe src including learning path context so the ResourceNodeVoter can detect LP access #}
    {% set iframe_src_with_lp = iframe_src %}
    {% if lp_id_num > 0 and lp_current_item_id_num > 0 %}
        {% if '?' in iframe_src_with_lp %}
            {% set iframe_src_with_lp = iframe_src_with_lp ~ '&origin=learnpath&lp_id=' ~ lp_id_num ~ '&lp_item_id=' ~ lp_current_item_id_num %}
        {% else %}
            {% set iframe_src_with_lp = iframe_src_with_lp ~ '?origin=learnpath&lp_id=' ~ lp_id_num ~ '&lp_item_id=' ~ lp_current_item_id_num %}
        {% endif %}
    {% endif %}

    {% autoescape false %}

        <div
                id="learning_path_main"
                class="lp-modern-view flex h-screen min-h-screen w-full overflow-hidden bg-gray-20 text-gray-90 {{ is_allowed_to_edit ? 'lp-view-include-breadcrumb' }} {{ lp_mode == 'embedframe' ? 'lp-view-collapsed' : '' }} {{ toc_hidden == 1 ? 'lp-toc-hidden' : '' }}"
        >
            {% if render_left_zone %}
                <div id="learning_path_left_zone" class="sidebar-scorm h-full overflow-hidden border-r border-gray-25 bg-white" aria-hidden="{{ toc_hidden == 1 ? 'true' : 'false' }}">
                    <div class="lp-view-zone-container">
                        <div id="scorm-info">
                            <div id="panel-scorm">
                                <div class="image-avatar">
                                    {% if lp_author == '' %}
                                        {{ lp_preview_image }}
                                    {% else %}
                                        <div class="media-author">
                                            <div class="media-author-avatar">
                                                {{ lp_preview_image }}
                                            </div>
                                            <div class="media-author-description">
                                                {{ lp_author }}
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                                {% if show_audio_player %}
                                    <div id="lp_media_file" class="audio-scorm">
                                        {{ media_player }}
                                    </div>
                                {% endif %}

                                {% if lp_accumulate_work_time != '' %}
                                    {% set lp_progress %}
                                    <script>
                                      $(function () {
                                        var timerData = {
                                          hour: parseInt($("#hour").text(), 10),
                                          minute: parseInt($("#minute").text(), 10),
                                          second: parseInt($("#second").text(), 10)
                                        }
                                        clearInterval(window.timerInterval)
                                        window.timerInterval = setInterval(function () {
                                          timerData.second++
                                          if (timerData.second >= 60) { timerData.second = 0; timerData.minute++ }
                                          if (timerData.minute >= 60) { timerData.minute = 0; timerData.hour++ }
                                          $("#hour").text(timerData.hour < 10 ? "0" + timerData.hour : timerData.hour)
                                          $("#minute").text(timerData.minute < 10 ? "0" + timerData.minute : timerData.minute)
                                          $("#second").text(timerData.second < 10 ? "0" + timerData.second : timerData.second)
                                        }, 1000)
                                      })
                                    </script>
                                    <div class="row">
                                        <div class="col-xs-4">
                                            <b>{{ "Progress"|trans|format(lp_accumulate_work_time) }}</b>
                                        </div>
                                        <div class="col-xs-8">
                                            <div id="progress_bar">{{ progress_bar }}</div>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-xs-4">
                                            <b>{{ "Time spent in the learning path"|trans|format(lp_accumulate_work_time) }}</b>
                                        </div>
                                        <div class="col-xs-8">
                                            <div id="timer">
                                                <div class="container">
                                                    <div id="hour">{{ hour }}</div>
                                                    <div class="divider">:</div>
                                                    <div id="minute">{{ minute }}</div>
                                                    <div class="divider">:</div>
                                                    <div id="second">{{ second }}</div>
                                                    <div id="slash"> /</div>
                                                    <div>{{ hour_min }}</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    {% endset %}
                                {% else %}
                                    {% set lp_progress %}
                                    <div id="progress_bar">{{ progress_bar }}</div>
                                    {% endset %}
                                {% endif %}

                                {% if gamification_mode == 1 %}
                                    <div id="scorm-gamification">
                                        <div class="row">
                                            <div class="col-xs-6">
                                                {% if gamification_stars > 0 %}
                                                    {% for i in 1..gamification_stars %}
                                                        <i class="level mdi-star-face mdi" aria-hidden="true"></i>
                                                    {% endfor %}
                                                {% endif %}
                                                {% if gamification_stars < 4 %}
                                                    {% for i in 1..4 - gamification_stars %}
                                                        <i class="mdi-home-outline mdi" aria-hidden="true"></i>
                                                    {% endfor %}
                                                {% endif %}
                                            </div>
                                            <div class="col-xs-6 text-right">
                                                {{ "%s points"|trans|format(gamification_points) }}
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-xs-12 navegation-bar">
                                                {{ lp_progress }}
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    {{ lp_progress }}
                                {% endif %}

                                {% if not is_lti_embeddable %}
                                    {{ teacher_toc_buttons }}
                                {% endif %}
                            </div>
                        </div>

                        <div id="toc_id" class="scorm-body" name="toc_name">
                            <div id="flag-mobile" class="visible-xs-block" aria-hidden="true"></div>
                            {% include '@ChamiloCore/LearnPath/scorm_list.html.twig' %}
                        </div>
                    </div>
                </div>
            {% endif %}
            <div
                    id="learning_path_right_zone"
                    class="content-scorm min-w-0 flex-1 overflow-hidden bg-gray-20 {{ (show_left_column != 1 or toc_hidden == 1) ? 'lp-content-full' : '' }}"
            >
                <div class="lp-view-zone-container flex h-full flex-col overflow-hidden bg-white">
                    <div class="lp-view-tabs relative flex min-h-0 flex-1 flex-col overflow-visible bg-white">
                        <div id="navTabBar" class="nav-tabs-bar">
                            <div class="text-left">
                                <h2 class="text-h3">{{ lp_title_scorm }}</h2>

                                {% if lp_flow_next_button is defined and lp_flow_next_button is not empty %}
                                    <div class="my-4">
                                        {{ lp_flow_next_button|raw }}
                                    </div>
                                {% endif %}

                                <div id="item-parent-names">
                                    {% for parent_title in lp_item_parents %}
                                        <h3 class="text-h5">{{ parent_title }}</h3>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>

                        {% include '@ChamiloCore/LearnPath/menubar.html.twig' %}

                        <div id="tab-iframe" class="auto tab-content min-h-0 flex-1 overflow-hidden bg-white p-0">
                            <div role="tabpanel" id="lp-view-content" class="h-full min-h-0 overflow-hidden">
                                <div id="wrapper-iframe" class="relative h-full min-h-0 max-w-full overflow-hidden rounded-xl bg-white">
                                    <div
                                            id="lp-iframe-loader"
                                            class="absolute inset-0 z-50 hidden items-center justify-center bg-white/75"
                                            aria-hidden="true"
                                    >
                                        <div class="flex items-center gap-2.5 rounded-xl bg-gray-90/70 px-3.5 py-2.5 text-sm text-white">
                                            <div
                                                    class="h-[18px] w-[18px] animate-spin rounded-full border-2 border-white/40 border-t-white"
                                                    aria-hidden="true"
                                            ></div>
                                            <div>Loading…</div>
                                        </div>
                                    </div>
                                    <div
                                            id="lp-video-next-overlay"
                                            class="absolute inset-0 z-[70] hidden items-center justify-center bg-gray-90/45 p-6"
                                            aria-hidden="true"
                                    >
                                        <div
                                                class="w-full max-w-[420px] rounded-[18px] border border-white/25 bg-white/95 p-6 text-center shadow-2xl"
                                                role="dialog"
                                                aria-modal="true"
                                                aria-labelledby="lp-video-next-title"
                                        >
                                            <div
                                                    class="mb-3 inline-flex h-14 w-14 items-center justify-center rounded-full bg-[rgb(var(--color-primary-base))] text-[32px] text-white"
                                                    aria-hidden="true"
                                            >
                                                <span class="mdi mdi-play-circle-outline"></span>
                                            </div>
                                            <div id="lp-video-next-title" class="text-xl font-bold leading-tight text-gray-90">{{ "Finished"|trans }}</div>
                                            <div class="mt-2 text-sm leading-relaxed text-gray-60">{{ "Continue"|trans }}</div>
                                            <div class="mt-5 flex flex-wrap justify-center gap-2">
                                                <button
                                                        type="button"
                                                        id="lp-video-next-button"
                                                        class="inline-flex min-h-10 cursor-pointer items-center justify-center gap-1.5 rounded-full border border-transparent bg-[rgb(var(--color-primary-base))] px-4 py-2 text-sm font-semibold text-white hover:brightness-95"
                                                >
                                                    <span class="mdi mdi-arrow-right-circle-outline" aria-hidden="true"></span>
                                                    {{ "Next step"|trans }}
                                                </button>
                                                <button
                                                        type="button"
                                                        id="lp-video-next-close"
                                                        class="inline-flex min-h-10 cursor-pointer items-center justify-center rounded-full border border-gray-30 bg-white px-4 py-2 text-sm font-semibold text-gray-70 hover:brightness-95"
                                                >
                                                    {{ "Close"|trans }}
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    {% if lp_mode == 'fullscreen' %}
                                        <iframe
                                                id="content_id_blank"
                                                class="block h-full w-full max-w-full rounded-xl border-0 bg-white"
                                                name="content_name_blank"
                                                src="blank.php"
                                                border="0"
                                                frameborder="0"
                                                allowfullscreen="true"
                                                webkitallowfullscreen="true"
                                                mozallowfullscreen="true"
                                        ></iframe>
                                    {% else %}
                                        <iframe
                                                id="content_id"
                                                class="block h-full w-full max-w-full rounded-xl border-0 bg-white"
                                                name="content_name"
                                                src="{{ iframe_src_with_lp }}"
                                                border="0"
                                                frameborder="0"
                                                allowfullscreen="true"
                                                webkitallowfullscreen="true"
                                                mozallowfullscreen="true"
                                        ></iframe>
                                    {% endif %}

                                    {% if ai_learning_helper_enabled|default(0) == 1 %}
                                        <div id="lp-ai-learning-helper-menu" class="fixed z-[1000000] hidden max-w-[260px]">
                                            <button
                                                    type="button"
                                                    id="lp-ai-learning-helper-open"
                                                    class="group relative inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary text-white shadow-xl ring-4 ring-primary/15 transition hover:-translate-y-0.5 hover:shadow-2xl hover:brightness-95 focus:outline-none focus:ring-4 focus:ring-primary/25"
                                                    aria-label="AI study helper"
                                                    title="AI study helper"
                                            >
                                                <i class="mdi mdi-robot-happy-outline text-2xl" aria-hidden="true"></i>
                                                <span class="mdi mdi-auto-fix absolute -right-1 -top-1 rounded-full bg-white px-1 py-0.5 text-xs leading-none text-primary shadow-sm" aria-hidden="true"></span>
                                                <span class="pointer-events-none absolute left-1/2 top-full mt-2 hidden -translate-x-1/2 whitespace-nowrap rounded-lg bg-gray-90 px-2.5 py-1 text-xs font-medium text-white shadow-lg group-hover:block group-focus:block">
                                                    AI study helper
                                                </span>
                                            </button>
                                        </div>
                                        <div
                                                id="lp-ai-learning-helper-modal"
                                                class="fixed inset-0 z-[1000001] hidden items-start justify-center overflow-y-auto overscroll-contain bg-gray-90/45 p-6"
                                                aria-hidden="true"
                                        >
                                            <div class="lp-ai-learning-helper-dialog flex max-h-[calc(100vh-48px)] w-full max-w-3xl flex-col overflow-hidden rounded-2xl bg-white p-6 shadow-xl">
                                                <div class="mb-4 flex items-start justify-between gap-4">
                                                    <div>
                                                        <h3 class="text-xl font-semibold text-gray-90">AI study helper</h3>
                                                        <p class="mt-1 text-sm text-gray-50">
                                                            Select a learning technique and generate a learner-friendly explanation from the selected text.
                                                        </p>
                                                    </div>
                                                    <button
                                                            type="button"
                                                            id="lp-ai-learning-helper-close"
                                                            class="rounded-lg p-2 text-gray-50 hover:bg-gray-15"
                                                            aria-label="Close"
                                                    >
                                                        <i class="mdi mdi-close text-xl" aria-hidden="true"></i>
                                                    </button>
                                                </div>
                                                <div class="lp-ai-learning-helper-body min-h-0 overflow-y-auto pr-1">
                                                    <div class="mb-4 rounded-xl border border-gray-25 bg-gray-15 p-3">
                                                        <div class="mb-1 text-xs font-semibold uppercase tracking-wide text-gray-50">Selected text</div>
                                                        <div id="lp-ai-learning-helper-selection" class="max-h-32 overflow-auto text-sm text-gray-90"></div>
                                                    </div>
                                                    <label for="lp-ai-learning-helper-method" class="mb-1 block text-sm font-semibold text-gray-90">
                                                        Learning technique
                                                    </label>
                                                    <select
                                                            id="lp-ai-learning-helper-method"
                                                            class="mb-4 w-full rounded-lg border border-gray-25 bg-white px-3 py-2 text-sm"
                                                    >
                                                        <option value="mind_map">Mind mapping</option>
                                                        <option value="feynman">Feynman Technique</option>
                                                        <option value="elaborative_interrogation">Elaborative interrogation</option>
                                                        <option value="spaced_repetition">Spaced repetition</option>
                                                        <option value="sq3r">SQ3R Method</option>
                                                        <option value="analogies_metaphors">Analogies and metaphors</option>
                                                        <option value="dual_coding">Dual coding</option>
                                                        <option value="storytelling">Storytelling</option>
                                                        <option value="thematic_connections">Thematic connections</option>
                                                        <option value="interleaved_learning">Interleaved learning</option>
                                                        <option value="memory_palace">Memory palaces</option>
                                                    </select>
                                                    <div class="mb-4 flex items-center gap-2">
                                                        <button
                                                                type="button"
                                                                id="lp-ai-learning-helper-generate"
                                                                class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white shadow-sm hover:opacity-90"
                                                        >
                                                            <i class="mdi mdi-auto-fix" aria-hidden="true"></i>
                                                            <span>Generate</span>
                                                        </button>
                                                        <span id="lp-ai-learning-helper-status" class="text-sm text-gray-50"></span>
                                                    </div>
                                                    <div id="lp-ai-learning-helper-answer-wrap" class="hidden rounded-xl border border-gray-25 bg-white p-4">
                                                        <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-50">AI response</div>
                                                        <div id="lp-ai-learning-helper-answer" class="max-h-[min(46vh,520px)] overflow-y-auto whitespace-pre-wrap pr-1 text-sm leading-6 text-gray-90"></div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                            <div role="tabpanel" class="tab-pane" id="lp-view-forum"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script>
          $(function () {
            var $main = $("#learning_path_main");

            function initLpAiLearningHelper() {
              var cfg = window.lpAiLearningHelper || {};
              if (Number(cfg.enabled) !== 1 || !cfg.endpoint || !cfg.lpItemId) {
                return;
              }

              var $menu = $("#lp-ai-learning-helper-menu");
              var $open = $("#lp-ai-learning-helper-open");
              var $modal = $("#lp-ai-learning-helper-modal");
              var $close = $("#lp-ai-learning-helper-close");
              var $selection = $("#lp-ai-learning-helper-selection");
              var $method = $("#lp-ai-learning-helper-method");
              var $generate = $("#lp-ai-learning-helper-generate");
              var $status = $("#lp-ai-learning-helper-status");
              var $answerWrap = $("#lp-ai-learning-helper-answer-wrap");
              var $answer = $("#lp-ai-learning-helper-answer");
              var selectedText = "";

              if (!$menu.length || !$modal.length) {
                return;
              }

              function getFrameElement() {
                return document.getElementById("content_id") || document.getElementById("content_id_blank");
              }

              function getFrameDocument() {
                var iframe = getFrameElement();
                if (!iframe || !iframe.contentWindow || !iframe.contentDocument) {
                  return null;
                }

                try {
                  return iframe.contentDocument;
                } catch (e) {
                  return null;
                }
              }

              function readSelectionFromDocument(doc) {
                if (!doc) {
                  return "";
                }

                try {
                  var selection = doc.getSelection ? doc.getSelection() : null;
                  return selection ? String(selection.toString() || "").trim() : "";
                } catch (e) {
                  return "";
                }
              }

              function readCurrentSelection() {
                var text = readSelectionFromDocument(getFrameDocument());
                if (text) {
                  return text;
                }

                try {
                  return String(window.getSelection ? window.getSelection().toString() : "").trim();
                } catch (e) {
                  return "";
                }
              }

              function hideMenu() {
                $menu.addClass("hidden").removeClass("block");
              }

              function showModal() {
                $modal.removeClass("hidden").addClass("flex").attr("aria-hidden", "false");
              }

              function hideModal() {
                $modal.removeClass("flex").addClass("hidden").attr("aria-hidden", "true");
              }

              function isCurrentLpDocumentItem() {
                try {
                  var currentId = Number(window.lpCurrentItemId || cfg.lpItemId || 0);
                  var type = "";

                  if (window.olms) {
                    if (currentId > 0 && olms.lms_item_types && olms.lms_item_types["i" + currentId]) {
                      type = String(olms.lms_item_types["i" + currentId]);
                    } else if (typeof olms.lms_item_type !== "undefined") {
                      type = String(olms.lms_item_type);
                    }
                  }

                  return !type || type === "document";
                } catch (e) {
                  return true;
                }
              }

              function normalizeSelectionPosition(x, y, sourceDocument) {
                var left = Number(x || 20);
                var top = Number(y || 20);

                try {
                  var iframe = getFrameElement();
                  if (sourceDocument && iframe && iframe.contentDocument === sourceDocument) {
                    var rect = iframe.getBoundingClientRect();
                    left += rect.left;
                    top += rect.top;
                  }
                } catch (e) {
                  // Ignore unavailable iframe coordinates.
                }

                return {
                  left: Math.max(12, Math.min(left, window.innerWidth - 80)),
                  top: Math.max(12, Math.min(top, window.innerHeight - 80))
                };
              }

              function showMenu(x, y, sourceDocument) {
                if (!isCurrentLpDocumentItem()) {
                  hideMenu();
                  return;
                }

                selectedText = readCurrentSelection();
                if (!selectedText) {
                  hideMenu();
                  return;
                }

                var maxLen = 5000;
                if (selectedText.length > maxLen) {
                  selectedText = selectedText.substring(0, maxLen);
                }

                var pos = normalizeSelectionPosition(x, y, sourceDocument || getFrameDocument());

                $menu
                  .css({ left: pos.left + "px", top: pos.top + "px" })
                  .removeClass("hidden")
                  .addClass("block");
              }

              function bindSelectionEvents() {
                var frameDoc = getFrameDocument();

                if (frameDoc && !frameDoc.__lpAiLearningHelperBound) {
                  frameDoc.__lpAiLearningHelperBound = true;

                  frameDoc.addEventListener("mouseup", function (event) {
                    setTimeout(function () {
                      showMenu(event.clientX + 12, event.clientY + 12, frameDoc);
                    }, 10);
                  });

                  frameDoc.addEventListener("keyup", function () {
                    setTimeout(function () {
                      var text = readCurrentSelection();
                      if (text) {
                        showMenu(24, 24, frameDoc);
                      } else {
                        hideMenu();
                      }
                    }, 10);
                  });

                  frameDoc.addEventListener("contextmenu", function (event) {
                    var text = readCurrentSelection();
                    if (!text) {
                      return;
                    }

                    event.preventDefault();
                    showMenu(event.clientX + 12, event.clientY + 12, frameDoc);
                  });
                }
              }

              var $iframe = $("#content_id, #content_id_blank").first();
              if ($iframe.length) {
                $iframe.off("load.lpAiLearningHelper").on("load.lpAiLearningHelper", function () {
                  setTimeout(bindSelectionEvents, 100);
                });
              }

              setTimeout(bindSelectionEvents, 300);
              setTimeout(bindSelectionEvents, 800);

              $(document).off("mouseup.lpAiLearningHelper").on("mouseup.lpAiLearningHelper", function (event) {
                if ($(event.target).closest("#lp-ai-learning-helper-menu, #lp-ai-learning-helper-modal").length) {
                  return;
                }

                setTimeout(function () {
                  var text = readCurrentSelection();
                  if (text) {
                    showMenu(event.clientX + 12, event.clientY + 12, document);
                  }
                }, 10);
              });

              $open.off("click.lpAiLearningHelper").on("click.lpAiLearningHelper", function () {
                if (!isCurrentLpDocumentItem()) {
                  hideMenu();
                  return;
                }

                selectedText = readCurrentSelection() || selectedText;
                if (!selectedText) {
                  return;
                }

                hideMenu();
                $selection.text(selectedText);
                $status.text("");
                $answer.text("");
                $answerWrap.addClass("hidden");
                showModal();
              });

              $close.off("click.lpAiLearningHelper").on("click.lpAiLearningHelper", function () {
                hideModal();
              });

              $modal.off("click.lpAiLearningHelperBackdrop").on("click.lpAiLearningHelperBackdrop", function (event) {
                if (event.target === $modal.get(0)) {
                  hideModal();
                }
              });

              $(document).off("keydown.lpAiLearningHelper").on("keydown.lpAiLearningHelper", function (event) {
                if (event.key === "Escape") {
                  hideMenu();
                  hideModal();
                }
              });

              $generate.off("click.lpAiLearningHelper").on("click.lpAiLearningHelper", function () {
                if (!selectedText) {
                  $status.text("Please select text first.");
                  return;
                }

                $generate.prop("disabled", true);
                $status.text("Generating...");
                $answer.text("");
                $answerWrap.addClass("hidden");

                var currentLpId = Number(window.lpId || cfg.lpId || 0);
                var currentLpItemId = Number(window.lpCurrentItemId || cfg.lpItemId || 0);
                var currentCid = Number(cfg.cid || 0);
                var currentSid = Number(cfg.sid || 0);
                var requestUrl = cfg.endpoint
                  + "?cid=" + encodeURIComponent(String(currentCid))
                  + "&sid=" + encodeURIComponent(String(currentSid))
                  + "&origin=learnpath"
                  + "&lp_id=" + encodeURIComponent(String(currentLpId))
                  + "&lp_item_id=" + encodeURIComponent(String(currentLpItemId));

                fetch(requestUrl, {
                  method: "POST",
                  credentials: "same-origin",
                  headers: {
                    "Content-Type": "application/json",
                    "X-Requested-With": "XMLHttpRequest"
                  },
                  body: JSON.stringify({
                    cid: currentCid,
                    sid: currentSid,
                    lp_id: currentLpId,
                    lp_item_id: currentLpItemId,
                    selected_text: selectedText,
