{% extends "@ChamiloCore/Layout/layout_one_col.html.twig" %}

{% block content %}
    <div class="space-y-6">
        <div class="rounded-2xl border border-gray-25 bg-white p-4 shadow-sm">
            <h1 class="m-0 text-2xl font-semibold text-gray-90">
                {{ 'Password strength checker'|trans }}
            </h1>

            <p class="mt-2 text-body-2 text-gray-50">
                {{ 'This report lists active users whose current password matches a list of commonly used passwords. The password itself is never displayed.'|trans }}
            </p>
        </div>

        {% if not has_scanned|default(false) %}
            <div id="password-strength-start-card" class="rounded-2xl border border-gray-25 bg-white p-4 shadow-sm">
                <p class="mb-4 text-body-2 text-gray-50">
                    {{ 'This scan can take time because every active user password has to be checked against a list of commonly used passwords. Passwords are never displayed.'|trans }}
                </p>

                <label for="password-strength-user-ids-filter" class="mb-2 block text-body-2 font-semibold text-gray-90">
                    {{ 'User IDs to scan'|trans }}
                </label>

                <input
                        type="text"
                        id="password-strength-user-ids-filter"
                        class="mb-3 w-full rounded-xl border border-gray-25 bg-white text-body-2 text-gray-90"
                        value="{{ scan_filter_user_ids|default('') }}"
                        placeholder="23,45"
                >

                <p class="mb-4 text-caption text-gray-50">
                    {{ 'Leave this field empty to scan all active users.'|trans }}
                </p>

                <button
                        type="button"
                        id="password-strength-start-button"
                        class="btn btn--primary inline-flex items-center gap-2 rounded-lg px-4 py-2 text-white"
                        title="{{ 'Run password strength scan'|trans }}"
                        aria-label="{{ 'Run password strength scan'|trans }}"
                >
                    <span class="mdi mdi-shield-search" aria-hidden="true"></span>
                    <span>{{ 'Run password strength scan'|trans }}</span>
                </button>
            </div>

            <div id="password-strength-progress-card" class="hidden rounded-2xl border border-gray-25 bg-white p-4 shadow-sm">
                <h2 class="m-0 text-body-1 font-semibold text-gray-90">
                    {{ 'Scanning passwords...'|trans }}
                </h2>

                <p class="mt-2 text-body-2 text-gray-50">
                    {{ 'Please wait. The scan is running asynchronously to avoid freezing the page.'|trans }}
                </p>

                <div class="mt-4 rounded-2xl border border-gray-25 bg-support-2 p-4">
                    <p class="m-0 text-body-2 text-gray-90">
                        {{ 'Verified users'|trans }}:
                        <strong id="password-strength-scanned-count">0</strong> /
                        <strong id="password-strength-total-count">0</strong>
                    </p>

                    <p class="m-0 mt-2 text-body-2 text-gray-90">
                        {{ 'Users with commonly used passwords found so far'|trans }}:
                        <strong id="password-strength-weak-count">0</strong>
                    </p>

                    <progress
                            id="password-strength-progress"
                            class="mt-4 h-4 w-full"
                            value="0"
                            max="1"
                    ></progress>

                    <p id="password-strength-current-user" class="m-0 mt-3 text-caption text-gray-50"></p>
                    <p id="password-strength-filter-info" class="m-0 mt-2 text-caption text-gray-50"></p>
                </div>

                <div class="mt-4">
                    <h3 class="m-0 text-body-2 font-semibold text-gray-90">
                        {{ 'Last verified users'|trans }}
                    </h3>

                    <ul id="password-strength-log" class="mt-2 max-h-64 overflow-auto rounded-2xl border border-gray-25 bg-white p-3 text-caption text-gray-90"></ul>
                </div>
            </div>

            <script>
              document.addEventListener('DOMContentLoaded', function () {
                var startButton = document.getElementById('password-strength-start-button');
                var startCard = document.getElementById('password-strength-start-card');
                var progressCard = document.getElementById('password-strength-progress-card');
                var scannedCount = document.getElementById('password-strength-scanned-count');
                var totalCount = document.getElementById('password-strength-total-count');
                var weakCount = document.getElementById('password-strength-weak-count');
                var progress = document.getElementById('password-strength-progress');
                var currentUser = document.getElementById('password-strength-current-user');
                var filterInfo = document.getElementById('password-strength-filter-info');
                var log = document.getElementById('password-strength-log');
                var userIdsFilter = document.getElementById('password-strength-user-ids-filter');
                var endpoint = {{ scan_endpoint|json_encode|raw }};
                var csrfToken = {{ csrf_token|json_encode|raw }};
                var isRunning = false;

                function appendLog(user, isWeak) {
                  if (!log || !user) {
                    return;
                  }

                  var item = document.createElement('li');
                  item.className = isWeak ? 'text-danger font-semibold' : 'text-gray-90';
                  item.textContent = user.name + ' (' + user.username + ')'
                    + (isWeak ? ' - {{ 'Commonly used password detected'|trans|e('js') }}' : '');

                  log.prepend(item);

                  while (log.children.length > 20) {
                    log.removeChild(log.lastChild);
                  }
                }

                function updateProgress(data) {
                  scannedCount.textContent = data.scanned_count;
                  totalCount.textContent = data.scan_total;
                  weakCount.textContent = data.weak_count;

                  progress.max = data.scan_total > 0 ? data.scan_total : 1;
                  progress.value = data.scanned_count;

                  if (filterInfo && data.filter_user_ids && data.filter_user_ids.length > 0) {
                    filterInfo.textContent = '{{ 'Filtered user IDs'|trans|e('js') }}: ' + data.filter_user_ids.join(', ');
                  }

                  if (data.scanned_users && data.scanned_users.length > 0) {
                    data.scanned_users.forEach(function (user) {
                      var isWeak = (data.weak_users || []).some(function (weakUser) {
                        return weakUser.id === user.id;
                      });

                      currentUser.textContent = '{{ 'Checking user'|trans|e('js') }}: ' + user.name + ' (' + user.username + ')';
                      appendLog(user, isWeak);
                    });
                  }
                }

                function scanBatch(restart) {
                  var body = new URLSearchParams();

                  body.append('_token', csrfToken);

                  if (restart) {
                    body.append('restart', '1');

                    if (userIdsFilter) {
                      body.append('user_ids_filter', userIdsFilter.value);
                    }
                  }

                  fetch(endpoint, {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/x-www-form-urlencoded',
                      'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: body.toString()
                  })
                    .then(function (response) {
                      if (!response.ok) {
                        throw new Error('Scan request failed.');
                      }

                      return response.json();
                    })
                    .then(function (data) {
                      updateProgress(data);

                      if (data.finished) {
                        window.setTimeout(function () {
                          window.location.reload();
                        }, 600);

                        return;
                      }

                      window.setTimeout(function () {
                        scanBatch(false);
                      }, 150);
                    })
                    .catch(function (error) {
                      isRunning = false;

                      if (currentUser) {
                        currentUser.textContent = error.message;
                        currentUser.classList.add('text-danger');
                      }

                      if (startButton) {
                        startButton.disabled = false;
                      }
                    });
                }

                if (startButton) {
                  startButton.addEventListener('click', function () {
                    if (isRunning) {
                      return;
                    }

                    isRunning = true;
                    startButton.disabled = true;
                    startCard.classList.add('hidden');
                    progressCard.classList.remove('hidden');
                    scanBatch(true);
                  });
                }
              });
            </script>
            {% elseif users is empty %}
            <div class="rounded-2xl border border-success bg-support-2 p-4 text-gray-90">
                {{ 'No users with commonly used passwords were found.'|trans }}
            </div>

            <form method="post" class="mt-4">
                <input type="hidden" name="_token" value="{{ csrf_token }}">

                <button
                        type="submit"
                        name="action"
                        value="scan_clear"
                        class="btn btn--plain inline-flex h-9 w-9 items-center justify-center rounded-lg p-0"
                        title="{{ 'Run a new scan'|trans }}"
                        aria-label="{{ 'Run a new scan'|trans }}"
                        data-native-tooltip="{{ 'Run a new scan'|trans }}"
                >
                    <span class="mdi mdi-refresh" aria-hidden="true"></span>
                </button>
            </form>
        {% else %}
            <form method="post" class="space-y-4">
                <input type="hidden" name="_token" value="{{ csrf_token }}">
                <input type="hidden" name="user_id" value="">

                <div class="flex flex-wrap items-center justify-between gap-2">
                    <p class="m-0 text-body-2 text-gray-50">
                        {{ 'Users with commonly used passwords found'|trans }}:
                        <strong>{{ weak_count }}</strong>
                    </p>

                    <div class="flex flex-wrap gap-2">
                        <button
                                type="submit"
                                name="action"
                                value="request_change"
                                class="btn btn--primary inline-flex h-9 w-9 items-center justify-center rounded-lg p-0 text-white"
                                title="{{ 'Request password change'|trans }}"
                                aria-label="{{ 'Request password change'|trans }}"
                                data-native-tooltip="{{ 'Request password change'|trans }}"
                        >
                            <span class="mdi mdi-email-outline" aria-hidden="true"></span>
                        </button>

                        <button
                                type="submit"
                                name="action"
                                value="force_reset"
                                class="btn btn--danger inline-flex h-9 w-9 items-center justify-center rounded-lg p-0 text-white"
                                title="{{ 'Forced password reset'|trans }}"
                                aria-label="{{ 'Forced password reset'|trans }}"
                                data-native-tooltip="{{ 'Forced password reset'|trans }}"
                                onclick="return confirm('{{ 'Are you sure you want to reset the selected users passwords?'|trans|e('js') }}');"
                        >
                            <span class="mdi mdi-lock-reset" aria-hidden="true"></span>
                        </button>

                        <button
                                type="submit"
                                name="action"
                                value="scan_clear"
                                class="btn btn--plain inline-flex h-9 w-9 items-center justify-center rounded-lg p-0"
                                title="{{ 'Run a new scan'|trans }}"
                                aria-label="{{ 'Run a new scan'|trans }}"
                                data-native-tooltip="{{ 'Run a new scan'|trans }}"
                        >
                            <span class="mdi mdi-refresh" aria-hidden="true"></span>
                        </button>
                    </div>
                </div>

                <div class="rounded-2xl border border-gray-25 bg-white p-4 shadow-sm">
                    <table class="data_table">
                        <thead>
                        <tr>
                            <th>
                                <input
                                        type="checkbox"
                                        title="{{ 'Select all'|trans }}"
                                        aria-label="{{ 'Select all'|trans }}"
                                        onclick="document.querySelectorAll('.js-user-selection').forEach(function (item) { item.checked = this.checked; }, this);"
                                >
                            </th>
                            <th>{{ 'Name'|trans }}</th>
                            <th>{{ 'Username'|trans }}</th>
                            <th>{{ 'E-mail'|trans }}</th>
                            <th>{{ 'Actions'|trans }}</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for user in users %}
                            <tr>
                                <td>
                                    <input
                                            type="checkbox"
                                            class="js-user-selection"
                                            name="user_ids[]"
                                            value="{{ user.id }}"
                                            title="{{ 'Select user'|trans }}"
                                            aria-label="{{ 'Select user'|trans }}"
                                    >
                                </td>
                                <td>{{ user.firstname }} {{ user.lastname }}</td>
                                <td>{{ user.username }}</td>
                                <td>{{ user.email }}</td>
                                <td>
                                    <div class="flex flex-wrap gap-2">
                                        <button
                                                type="submit"
                                                name="action"
                                                value="request_change"
                                                onclick="this.form.user_id.value='{{ user.id }}';"
                                                class="btn btn--primary inline-flex h-8 w-8 items-center justify-center rounded-lg p-0 text-white"
                                                title="{{ 'Request password change'|trans }}"
                                                aria-label="{{ 'Request password change'|trans }}"
                                                data-native-tooltip="{{ 'Request password change'|trans }}"
                                        >
                                            <span class="mdi mdi-email-outline" aria-hidden="true"></span>
                                        </button>

                                        <button
                                                type="submit"
                                                name="action"
                                                value="force_reset"
                                                onclick="this.form.user_id.value='{{ user.id }}'; return confirm('{{ 'Are you sure you want to reset this user password?'|trans|e('js') }}');"
                                                class="btn btn--danger inline-flex h-8 w-8 items-center justify-center rounded-lg p-0 text-white"
                                                title="{{ 'Forced password reset'|trans }}"
                                                aria-label="{{ 'Forced password reset'|trans }}"
                                                data-native-tooltip="{{ 'Forced password reset'|trans }}"
                                        >
                                            <span class="mdi mdi-lock-reset" aria-hidden="true"></span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </form>
        {% endif %}
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var tooltip = null;

        function removeTooltip() {
          if (tooltip) {
            tooltip.remove();
            tooltip = null;
          }
        }

        function showTooltip(element) {
          var text = element.getAttribute('data-native-tooltip');

          if (!text) {
            return;
          }

          removeTooltip();

          tooltip = document.createElement('div');
          tooltip.className = 'pointer-events-none fixed z-50 rounded-lg bg-gray-90 px-2 py-1 text-caption font-normal text-white shadow-sm';
          tooltip.textContent = text;

          document.body.appendChild(tooltip);

          var elementRect = element.getBoundingClientRect();
          var tooltipRect = tooltip.getBoundingClientRect();

          var top = elementRect.top - tooltipRect.height - 8;
          var left = elementRect.left + (elementRect.width / 2) - (tooltipRect.width / 2);

          if (top < 8) {
            top = elementRect.bottom + 8;
          }

          if (left < 8) {
            left = 8;
          }

          if (left + tooltipRect.width > window.innerWidth - 8) {
            left = window.innerWidth - tooltipRect.width - 8;
          }

          tooltip.style.top = top + 'px';
          tooltip.style.left = left + 'px';
        }

        document.querySelectorAll('[data-native-tooltip]').forEach(function (element) {
          element.addEventListener('mouseenter', function () {
            showTooltip(element);
          });

          element.addEventListener('focus', function () {
            showTooltip(element);
          });

          element.addEventListener('mouseleave', removeTooltip);
          element.addEventListener('blur', removeTooltip);
        });

        window.addEventListener('scroll', removeTooltip, true);
        window.addEventListener('resize', removeTooltip);
      });
    </script>
{% endblock %}
