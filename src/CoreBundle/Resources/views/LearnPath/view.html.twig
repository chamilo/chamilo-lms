              $close.off("click.lpAiLearningHelper").on("click.lpAiLearningHelper", function () {
                $modal.removeClass("lp-ai-open").attr("aria-hidden", "true");
              });

              $modal.off("click.lpAiLearningHelperBackdrop").on("click.lpAiLearningHelperBackdrop", function (event) {
                if (event.target === $modal.get(0)) {
                  $modal.removeClass("lp-ai-open").attr("aria-hidden", "true");
                }
              });

              $generate.off("click.lpAiLearningHelper").on("click.lpAiLearningHelper", function () {
                if (!selectedText) {
                  $status.text("Please select text first.");
                  return;
                }

                $generate.prop("disabled", true);
                $status.text("Generating...");
                $answer.text("");
                $answerWrap.addClass("hidden");

                var currentLpId = Number(window.lpId || cfg.lpId || 0);
                var currentLpItemId = Number(window.lpCurrentItemId || cfg.lpItemId || 0);
                var currentCid = Number(cfg.cid || 0);
                var currentSid = Number(cfg.sid || 0);
                var requestUrl = cfg.endpoint
                  + "?cid=" + encodeURIComponent(String(currentCid))
                  + "&sid=" + encodeURIComponent(String(currentSid))
                  + "&origin=learnpath"
                  + "&lp_id=" + encodeURIComponent(String(currentLpId))
                  + "&lp_item_id=" + encodeURIComponent(String(currentLpItemId));

                fetch(requestUrl, {
                  method: "POST",
                  credentials: "same-origin",
                  headers: {
                    "Content-Type": "application/json",
                    "X-Requested-With": "XMLHttpRequest"
                  },
                  body: JSON.stringify({
                    cid: currentCid,
                    sid: currentSid,
                    lp_id: currentLpId,
                    lp_item_id: currentLpItemId,
                    selected_text: selectedText,
                    method: String($method.val() || "feynman"),
                    language: String(cfg.language || "en")
                  })
                })
                  .then(function (response) {
                    return response.json().then(function (json) {
                      return { ok: response.ok, json: json };
                    });
                  })
                  .then(function (result) {
                    if (!result.ok || !result.json || !result.json.success) {
                      throw new Error((result.json && result.json.text) ? result.json.text : "AI request failed.");
                    }

                    $answer.text(result.json.text || "");
                    $answerWrap.removeClass("hidden");
                    $status.text("");
                  })
                  .catch(function (error) {
                    $status.text(error.message || "AI request failed.");
                  })
                  .finally(function () {
                    $generate.prop("disabled", false);
                  });
              });
            }

            initLpAiLearningHelper();
            var tocHiddenSetting = $main.hasClass("lp-toc-hidden") ? 1 : 0;

            var $menu = $("#btn-menu-float");
            if (!$menu.length) {
              console.warn("LP: floating menu not found (#btn-menu-float).");
              return;
            }

            // Prefer data attributes, fallback to legacy classes.
            var $circle = $menu.find("[data-lp-menu='circle']").first();
            if (!$circle.length) {
              $circle = $menu.find(".circle").first();
            }

            var $toggle = $menu.find("[data-lp-menu='toggle']").first();
            if (!$toggle.length) {
              $toggle = $menu.find(".menu-button").first();
            }

            function cleanupLtiEmbedMenu() {
              if (window.isLtiEmbeddable !== 1) {
                return;
              }
              $("#home-course").remove();
              $("#lp-view-info-toggle, #lp-view-item-info, #lp-view-item-info-btn").remove();
              $("#btn-menu-float i.mdi-information, #btn-menu-float i.mdi-information-outline")
                .closest("a, button, .icon-toolbar")
                .remove();
            }

            function updateMenuLayout() {
              // Layout rules:
              // - Real TOC hidden setting -> top-right + vertical panel
              // - Collapsed TOC (lp-view-collapsed) -> left + vertical panel
              // - Normal mode -> left + horizontal panel
              var isTocHidden = $main.hasClass("lp-toc-hidden");
              var isCollapsed = $main.hasClass("lp-view-collapsed");
              $menu.toggleClass("lp-menu-top-right", isTocHidden);
              $menu.toggleClass("lp-menu-vertical", isTocHidden || isCollapsed);
            }

            updateMenuLayout();
            cleanupLtiEmbedMenu();
            // Observe class changes to keep menu layout consistent (covers expand/collapse toggles).
            try {
              var mo = new MutationObserver(function () {
                updateMenuLayout();
              });
              mo.observe($main.get(0), { attributes: true, attributeFilter: ["class"] });
            } catch (e) {
              console.warn("LP: MutationObserver not available, menu layout will update only on known actions.");
            }

            // Auto-open only once when TOC is hidden by setting (do not fight the user after that).
            if (tocHiddenSetting === 1 && $circle.length && $toggle.length) {
              if (!$menu.data("lpAutoOpened")) {
                $circle.addClass("open");
                $toggle.addClass("menu-button-selected");
                $menu.data("lpAutoOpened", true);
              }
            }

            // Toggle only this LP menu (avoid global selectors) - and NEVER navigate on toggle.
            if ($toggle.length && $circle.length) {
              $toggle.off("click.lpMenu").on("click.lpMenu", function (e) {
                e.preventDefault();
                e.stopPropagation();

                $circle.toggleClass("open");
                $toggle.toggleClass("menu-button-selected");

                return false;
              });
            } else {
              console.warn("LP: menu toggle/circle not found. Toggle binding skipped.");
            }

            // Expand/collapse only when TOC is visible (setting != 1)
              {% if toc_hidden != 1 %}
              {% if lp_mode == 'embedframe' %}
            $("#lp-view-expand-toggle").off("click.lpExpand").on("click.lpExpand", function (e) {
              e.preventDefault();
              $main.toggleClass("lp-view-collapsed");
              $("#lp-view-expand-toggle i.mdi").toggleClass("mdi-arrow-expand-horizontal");
              $("#lp-view-expand-toggle i.mdi").toggleClass("mdi-arrow-collapse-horizontal");
              updateMenuLayout();
            });
              {% else %}
            $("#lp-view-expand-toggle").off("click.lpExpand").on("click.lpExpand", function (e) {
              e.preventDefault();
              $main.toggleClass("lp-view-collapsed");
              $("#lp-view-expand-toggle i.mdi").toggleClass("mdi-arrow-collapse-horizontal");
              $("#lp-view-expand-toggle i.mdi").toggleClass("mdi-arrow-expand-horizontal");
              updateMenuLayout();
            });
              {% endif %}
              {% endif %}

            // Debug: show what iframe is currently loading
            try {
              var iframeSrc = $("#content_id").attr("src") || $("#content_id_blank").attr("src") || "";
              console.info("LP: current iframe src =", iframeSrc);
            } catch (e) {
              console.warn("LP: cannot read iframe src:", e);
            }

            function isRealHref(href) {
              return href && href !== "#" && href.indexOf("javascript:") !== 0;
            }

            function extractUrlFromOnclick(onclickValue) {
              if (!onclickValue) return "";

              // 1) frames.content_name.location='...'
              var m1 = onclickValue.match(/content_name(?:_blank)?\.location(?:\.href)?\s*=\s*['"]([^'"]+)['"]/);
              if (m1 && m1[1]) return m1[1];

              // 2) Any direct lp_controller.php... in onclick
              var m2 = onclickValue.match(/(lp_controller\.php[^'"]+)/);
              if (m2 && m2[1]) return m2[1];

              // 3) Fallback: any lp_view.php / lp_content.php inside onclick
              var m3 = onclickValue.match(/(lp_(?:view|content)\.php[^'"]+)/);
              if (m3 && m3[1]) return m3[1];

              return "";
            }

            function resolveUrl(el) {
              var $el = $(el);

              // Prefer patched URL if present
              var patched = $el.attr("data-lp-nav-url") || "";
              if (patched) return patched;

              var href = $el.attr("href") || "";
              if (isRealHref(href)) return href;

              var onclickValue = $el.attr("onclick") || "";
              return extractUrlFromOnclick(onclickValue);
            }

            function getNumeric(v) {
              var n = Number(v);
              return Number.isFinite(n) ? n : 0;
            }

            function getSearchParam(name) {
              try {
                var sp = new URLSearchParams(window.location.search || "");
                return sp.get(name) || "";
              } catch (e) {
                return "";
              }
            }

            /* -----------------------------
             * Iframe helpers
             * ----------------------------- */
            function getLpIframe() {
              var $i = $("#content_id");
              if (!$i.length) {
                $i = $("#content_id_blank");
              }
              return $i;
            }

            function syncCurrentItemFromIframe() {
              try {
                var $i = getLpIframe();
                if (!$i.length) {
                  return;
                }
                var src = $i.attr("src") || "";
                var m = src.match(/[?&]item_id=(\d+)/);
                if (m && m[1]) {
                  window.lpCurrentItemId = parseInt(m[1], 10) || window.lpCurrentItemId;
                }
              } catch (e) {}
            }

            /* -----------------------------------------------------------
             * TOC-based navigation helpers
             * ----------------------------------------------------------- */
            function collectTocItemIds() {
              var ids = [];
              var seen = {};

              $("#toc_id [id^='toc_']").each(function () {
                var raw = (this.id || "").replace("toc_", "");
                var n = parseInt(raw, 10);
                if (!Number.isFinite(n) || n <= 0) return;
                if (seen[n]) return;
                seen[n] = true;
                ids.push(n);
              });

              if (!ids.length) {
                $("#toc_id a[href*='item_id=']").each(function () {
                  try {
                    var href = $(this).attr("href") || "";
                    var m = href.match(/[?&]item_id=(\d+)/);
                    if (!m) return;
                    var n = parseInt(m[1], 10);
                    if (!Number.isFinite(n) || n <= 0) return;
                    if (seen[n]) return;
                    seen[n] = true;
                    ids.push(n);
                  } catch (e) {}
                });
              }

              return ids;
            }

            function getCurrentItemIdSafe() {
              // Prefer runtime value (most reliable when available)
              try {
                if (window.olms && typeof olms.lms_item_id !== "undefined") {
                  var n = parseInt(olms.lms_item_id, 10);
                  if (Number.isFinite(n) && n > 0) return n;
                }
              } catch (e) {}

              var fromWindow = getNumeric(window.lpCurrentItemId);
              if (fromWindow > 0) return fromWindow;

              var fromUrl = parseInt(getSearchParam("item_id"), 10);
              return Number.isFinite(fromUrl) ? fromUrl : 0;
            }

            function resolveDirectionToId(direction, currentId) {
              var ids = collectTocItemIds();
              if (!ids.length) {
                return 0;
              }

              var idx = ids.indexOf(currentId);
              if (idx === -1) {
                return direction === "next" ? (ids[0] || 0) : 0;
              }

              if (direction === "next") {
                return ids[idx + 1] || 0;
              }
              if (direction === "previous") {
                return ids[idx - 1] || 0;
              }
              return 0;
            }

            function buildContentUrlForItem(itemId) {
              var cid = getSearchParam("cid") || "";
              var sid = getSearchParam("sid") || "0";
              var lpId = String(getNumeric(window.lpId) || {{ lp_id_num }});
              return "lp_controller.php?action=content"
                + "&cid=" + encodeURIComponent(cid)
                + "&sid=" + encodeURIComponent(sid)
                + "&origin=learnpath"
                + "&lp_id=" + encodeURIComponent(lpId)
                + "&lp_item_id=" + encodeURIComponent(String(itemId))
                + "&item_id=" + encodeURIComponent(String(itemId));
            }

            // Iframe loading overlay (UX-friendly: delayed + minimum visible time)
            var $loader = $("#lp-iframe-loader");
            var $iframe = getLpIframe();

            var loaderShowDelayMs = 250;      // Do not show loader for very fast loads
            var loaderMinVisibleMs = 250;     // Avoid flicker if it appears
            var loaderShowTimer = null;
            var loaderHideTimer = null;
            var loaderVisibleSince = 0;
            var loaderMaxHideTimer = null;

            function showLoaderNow(reason) {
              if (!$loader.length) return;
              if ($loader.hasClass("is-visible")) return;

              loaderVisibleSince = Date.now();
              $loader.addClass("is-visible").attr("aria-hidden", "false");

              clearTimeout(loaderMaxHideTimer);
              loaderMaxHideTimer = setTimeout(function () {
                hideLoader("timeout");
              }, 15000);
            }

            function scheduleShowLoader(reason) {
              if (!$loader.length) return;

              clearTimeout(loaderShowTimer);
              loaderShowTimer = setTimeout(function () {
                showLoaderNow(reason || "delayed");
              }, loaderShowDelayMs);
            }

            function showLoader(reason) {
              scheduleShowLoader(reason || "manual");
            }

            function hideLoader(reason) {
              if (!$loader.length) return;

              clearTimeout(loaderShowTimer);
              clearTimeout(loaderHideTimer);

              if (!$loader.hasClass("is-visible")) {
                clearTimeout(loaderMaxHideTimer);
                return;
              }

              var elapsed = Date.now() - (loaderVisibleSince || 0);
              if (elapsed < loaderMinVisibleMs) {
                loaderHideTimer = setTimeout(function () {
                  hideLoader(reason || "min-visible");
                }, loaderMinVisibleMs - elapsed);
                return;
              }

              $loader.removeClass("is-visible").attr("aria-hidden", "true");
              clearTimeout(loaderMaxHideTimer);
            }

// Initial iframe load: delay the loader (no blink)
            if ($iframe.length) {
              scheduleShowLoader("initial");
              $iframe.off("load.lpLoader").on("load.lpLoader", function () {
                syncCurrentItemFromIframe();
                hideLoader("iframe load");
              });
            } else {
              console.warn("LP: iframe not found (#content_id / #content_id_blank).");
            }

            $(document).off("click.lpLoaderNav").on(
              "click.lpLoaderNav",
              "#toc_id a, #btn-menu-float a, #btn-menu-float button",
              function () {
                var $t = $(this);

                // Do NOT show loader for the menu toggle (open/close).
                if ($toggle.length && ($t.is($toggle) || $t.closest($toggle).length)) {
                  return;
                }

                // Only show loader when this looks like real navigation.
                var href = ($t.attr("href") || "");
                var onclickValue = ($t.attr("onclick") || "");

                var isKnownNavButton = $t.is("#scorm-next, #scorm-previous, #home-course");
                var isTocClick = $t.closest("#toc_id").length > 0;

                var isLpContentLink =
                  href.indexOf("lp_controller.php") !== -1 ||
                  href.indexOf("lp_view.php") !== -1 ||
                  href.indexOf("lp_content.php") !== -1 ||
                  onclickValue.indexOf("lp_controller.php") !== -1 ||
                  onclickValue.indexOf("lp_view.php") !== -1 ||
                  onclickValue.indexOf("lp_content.php") !== -1 ||
                  onclickValue.indexOf("content_name") !== -1;

                if (!isKnownNavButton && !isTocClick && !isLpContentLink) {
                  return;
                }

                // Delay loader so fast loads don't show anything.
                scheduleShowLoader("nav click");
              }
            );

            function lpNavigateToItem(target, label) {
              var isDirection = (target === "next" || target === "previous" || target === "first" || target === "last");
              var targetItemId = 0;

              showLoader("navigate " + label);
              var currentItemId = getCurrentItemIdSafe();

              // If target is numeric, validate it.
              if (!isDirection) {
                targetItemId = parseInt(target, 10);
                if (!Number.isFinite(targetItemId) || targetItemId <= 0) {
                  console.warn("LP NAV: invalid target item id for " + label + ":", target);
                  hideLoader("nav failed");
                  return false;
                }
              }

              // If direction, first resolve it from TOC order (best for Chamilo LP).
              if (isDirection && (target === "next" || target === "previous")) {
                var tocResolved = resolveDirectionToId(target, currentItemId);
                if (tocResolved > 0 && tocResolved !== currentItemId) {
                  targetItemId = tocResolved;
                }
              }

              // Prefer switch_item if runtime is ready (keeps SCORM/LP state).
              if (window.olms && typeof switch_item === "function" && Number(olms.lms_initialized) === 1) {
                console.info("LP NAV: switching item via runtime", {
                  currentItemId: currentItemId,
                  target: isDirection ? (targetItemId > 0 ? targetItemId : target) : targetItemId
                });

                try {
                  // If we resolved a numeric target, pass numeric. Otherwise pass direction.
                  switch_item(currentItemId || 0, isDirection ? (targetItemId > 0 ? targetItemId : target) : targetItemId);
                  if (!isDirection || targetItemId > 0) {
                    window.lpCurrentItemId = targetItemId;
                  }
                  return true;
                } catch (e) {
                  console.warn("LP NAV: switch_item() failed, falling back to iframe src update.", e);
                }
              }

              // Fallback: resolve direction from runtime vars only if TOC resolution failed.
              if (isDirection && targetItemId <= 0 && window.olms) {
                try {
                  if (target === "next") targetItemId = parseInt(olms.lms_next_item, 10) || 0;
                  if (target === "previous") targetItemId = parseInt(olms.lms_previous_item, 10) || 0;
                } catch (e) {}
              }

              // Final fallback: update iframe src directly.
              if (targetItemId > 0) {
                var $i = getLpIframe();
                if ($i.length) {
                  var src = buildContentUrlForItem(targetItemId);
                  console.info("LP NAV: updating iframe src (fallback).", src);
                  $i.attr("src", src);
                  window.lpCurrentItemId = targetItemId;
                  return true;
                }
              }

              hideLoader("nav failed");
              return false;
            }

            /* -----------------------------------------------------------
             * Deterministic bindings for Next/Previous (Chamilo LP safe)
             * ----------------------------------------------------------- */
            function bindPrimaryNavButtons() {
              var $prev = $("#scorm-previous");
              var $next = $("#scorm-next");

              function bind($el, direction, label) {
                if (!$el || !$el.length) return;

                // Tag for easier debugging
                $el.attr("data-lp-nav", direction);

                // Remove legacy inline handlers to prevent NaN or dead navigation.
                // We still keep behavior via lpNavigateToItem().
                $el.removeAttr("onclick").removeAttr("target");

                if ($el.is("a")) {
                  $el.attr("href", "#");
                }

                $el.off("click.lpNavPrimary").on("click.lpNavPrimary", function (e) {
                  e.preventDefault();
                  e.stopPropagation();
                  console.info("LP NAV: " + label + " clicked -> navigating", direction);
                  lpNavigateToItem(direction, label);
                  return false;
                });
              }

              if (!$prev.length || !$next.length) {
                console.warn("LP NAV: primary #scorm-previous/#scorm-next elements not found. Will rely on heuristic patching.");
              }

              bind($prev, "previous", "previous");
              bind($next, "next", "next");
            }

            function looksLikePrev(el) {
              var $el = $(el);
              var t = ($el.attr("title") || "").toLowerCase();
              var a = ($el.attr("aria-label") || "").toLowerCase();
              var h = ($el.html() || "").toLowerCase();
              var s = [t, a, h].join(" ");

              return (
                s.indexOf("previous") !== -1 ||
                s.indexOf("prev") !== -1 ||
                s.indexOf("anterior") !== -1 ||
                s.indexOf("mdi-chevron-left") !== -1 ||
                s.indexOf("mdi-arrow-left") !== -1
              );
            }

            function looksLikeNext(el) {
              var $el = $(el);
              var t = ($el.attr("title") || "").toLowerCase();
              var a = ($el.attr("aria-label") || "").toLowerCase();
              var h = ($el.html() || "").toLowerCase();
              var s = [t, a, h].join(" ");

              return (
                s.indexOf("next") !== -1 ||
                s.indexOf("siguiente") !== -1 ||
                s.indexOf("mdi-chevron-right") !== -1 ||
                s.indexOf("mdi-arrow-right") !== -1
              );
            }

            function patchNavArrowsWhenTocHidden() {
              if (tocHiddenSetting !== 1) return;

              // Prefer known IDs if present (most reliable)
              var $prevEl = $("#scorm-previous");
              var $nextEl = $("#scorm-next");

              // If not found, fallback to heuristics inside the floating menu
              if (!$prevEl.length || !$nextEl.length) {
                var $candidates = $menu
                  .find("a, button")
                  .not("#home-course")
                  .not("#lp-view-expand-toggle")
                  .not("[data-lp-menu='toggle']");

                $prevEl = $prevEl.length ? $prevEl : $();
                $nextEl = $nextEl.length ? $nextEl : $();

                $candidates.each(function () {
                  if (!$prevEl.length && looksLikePrev(this)) $prevEl = $(this);
                  if (!$nextEl.length && looksLikeNext(this)) $nextEl = $(this);
                });
              }

              function applyPatchDirection($el, direction, label) {
                if (!$el || !$el.length) {
                  console.warn("LP NAV: cannot patch " + label + " (element not found).");
                  return;
                }

                $el.removeAttr("onclick").removeAttr("target");
                if ($el.is("a")) {
                  $el.attr("href", "#");
                }

                $el.off("click.lpNav").on("click.lpNav", function (e) {
                  e.preventDefault();
                  e.stopPropagation();
                  console.info("LP NAV: " + label + " clicked -> navigating direction", direction);
                  lpNavigateToItem(direction, label);
                  return false;
                });
              }

              applyPatchDirection($prevEl, "previous", "previous");
              applyPatchDirection($nextEl, "next", "next");
            }

            // When TOC is hidden, keep LP content navigation inside the iframe named "content_name".
            if (tocHiddenSetting === 1) {
              $menu.find("a").each(function () {
                var url = resolveUrl(this);
                if (!url) return;

                // If it's LP content navigation, ensure it targets the content iframe.
                var isLpContent =
                  url.indexOf("lp_controller.php") !== -1 &&
                  url.indexOf("action=content") !== -1;

                if (!isLpContent) return;

                var $a = $(this);
                var target = ($a.attr("target") || "").toLowerCase();

                if (!target || target === "_self" || target === "_top") {
                  $a.attr("target", "content_name");
                }
              });
            }

            // Keep original hook (guarded)
            try {
              if (typeof checkCurrentItemPosition === "function") {
                checkCurrentItemPosition({{ lp_current_item_id_num }});
              } else {
                console.warn("LP: checkCurrentItemPosition() is not available.");
              }
            } catch (err) {
              console.warn("LP: checkCurrentItemPosition() failed:", err);
            }

              {% if disable_js_in_lp_view == 0 %}
            try {
              var allowedTypes = ["link", "sco"];
              if (window.olms && typeof olms.lms_item_type !== "undefined") {
                if ($.inArray(olms.lms_item_type, allowedTypes) === -1) {
                    {{ frame_ready }}
                }
              } else {
                console.warn("LP: olms is not ready; skipping frame_ready hook.");
              }
            } catch (err) {
              console.warn("LP: frame_ready hook failed:", err);
            }
              {% endif %}

            function patchNavArrowsWhenTocHiddenSafe() {
              if (tocHiddenSetting !== 1) return;

              try {
                patchNavArrowsWhenTocHidden();
              } catch (e) {
                console.warn("LP NAV: patchNavArrowsWhenTocHidden() failed:", e);
              }
            }

            // Bind primary next/prev always (safe for Chamilo LP + SCORM)
            bindPrimaryNavButtons();
            setTimeout(bindPrimaryNavButtons, 200);
            setTimeout(bindPrimaryNavButtons, 600);
            setTimeout(cleanupLtiEmbedMenu, 200);
            setTimeout(cleanupLtiEmbedMenu, 600);
            if (tocHiddenSetting === 1) {
              // Run immediately + retries (menu markup sometimes arrives late)
              patchNavArrowsWhenTocHiddenSafe();
              setTimeout(patchNavArrowsWhenTocHiddenSafe, 200);
              setTimeout(patchNavArrowsWhenTocHiddenSafe, 600);
            }

          });
        </script>
    {% endautoescape %}
{% endblock %}
