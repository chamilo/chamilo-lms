            function normalizeYoutubeIframeSrc(iframe) {
              var src = iframe.getAttribute("src") || "";

              if (!src || src.indexOf("youtube.com/embed/") === -1 && src.indexOf("youtube-nocookie.com/embed/") === -1) {
                return false;
              }

              try {
                var url = new URL(src, window.location.href);
                if (url.searchParams.get("enablejsapi") !== "1") {
                  url.searchParams.set("enablejsapi", "1");
                }
                if (!url.searchParams.get("origin")) {
                  url.searchParams.set("origin", window.location.origin);
                }
                var normalized = url.toString();

                if (normalized !== src) {
                  iframe.setAttribute("src", normalized);
                }

                return true;
              } catch (e) {
                return false;
              }
            }

            function loadYoutubeIframeApi(callback) {
              if (window.YT && window.YT.Player) {
                callback();
                return;
              }

              lpYoutubeApiReadyCallbacks.push(callback);

              if (lpYoutubeApiLoading) {
                return;
              }

              lpYoutubeApiLoading = true;

              var previousReady = window.onYouTubeIframeAPIReady;
              window.onYouTubeIframeAPIReady = function () {
                if (typeof previousReady === "function") {
                  try {
                    previousReady();
                  } catch (e) {}
                }

                var callbacks = lpYoutubeApiReadyCallbacks.slice();
                lpYoutubeApiReadyCallbacks = [];

                callbacks.forEach(function (cb) {
                  try {
                    cb();
                  } catch (e) {
                    console.warn("LP video overlay: YouTube callback failed.", e);
                  }
                });
              };

              var script = document.createElement("script");
              script.src = "https://www.youtube.com/iframe_api";
              script.async = true;
              document.head.appendChild(script);
            }

            function watchHtml5Videos(doc) {
              var videos = [];

              try {
                videos = Array.prototype.slice.call(doc.querySelectorAll("video"));
              } catch (e) {
                videos = [];
              }

              videos.forEach(function (video) {
                var endedHandler = function () {
                  showVideoNextOverlay();
                };
                var playingHandler = function () {
                  hideVideoNextOverlay();
                };

                video.addEventListener("ended", endedHandler);
                video.addEventListener("play", playingHandler);
                video.addEventListener("seeking", playingHandler);

                lpVideoNextCleanup.push(function () {
                  video.removeEventListener("ended", endedHandler);
                  video.removeEventListener("play", playingHandler);
                  video.removeEventListener("seeking", playingHandler);
                });
              });

              return videos.length;
            }

            function watchYoutubeIframes(doc) {
              var iframes = [];

              try {
                iframes = Array.prototype.slice.call(doc.querySelectorAll("iframe"));
              } catch (e) {
                iframes = [];
              }

              iframes = iframes.filter(function (iframe) {
                return normalizeYoutubeIframeSrc(iframe);
              });

              if (!iframes.length) {
                return 0;
              }

              loadYoutubeIframeApi(function () {
                iframes.forEach(function (iframe) {
                  try {
                    var player = new YT.Player(iframe, {
                      events: {
                        onStateChange: function (event) {
                          if (event.data === YT.PlayerState.ENDED) {
                            showVideoNextOverlay();
                          }
                          if (event.data === YT.PlayerState.PLAYING) {
                            hideVideoNextOverlay();
                          }
                        }
                      }
                    });

                    lpVideoNextCleanup.push(function () {
                      try {
                        if (player && typeof player.destroy === "function") {
                          player.destroy();
                        }
                      } catch (e) {}
                    });
                  } catch (e) {
                    console.warn("LP video overlay: cannot attach YouTube player.", e);
                  }
                });
              });

              return iframes.length;
            }

            function setupVideoNextOverlay() {
              clearVideoNextWatchers();

              if (!hasNextLpItem()) {
                return;
              }

              var $i = getLpIframe();
              if (!$i.length) {
                return;
              }

              try {
                var iframe = $i.get(0);
                var doc = iframe.contentDocument || iframe.contentWindow.document;

                if (!doc) {
                  return;
                }

                var detected = watchHtml5Videos(doc);
                detected += watchYoutubeIframes(doc);

                if (detected > 0) {
                  console.info("LP video overlay: watching video players.", detected);
                }
              } catch (e) {
                // Cross-origin content cannot be inspected. Keep the standard LP navigation untouched.
                console.warn("LP video overlay: cannot inspect iframe content.", e);
              }
            }

            $videoNextButton.off("click.lpVideoNext").on("click.lpVideoNext", function (e) {
              e.preventDefault();
              hideVideoNextOverlay();
              lpNavigateToItem("next", "video ended overlay");
            });

            $videoNextClose.off("click.lpVideoNext").on("click.lpVideoNext", function (e) {
              e.preventDefault();
              hideVideoNextOverlay();
            });

            function showLoaderNow(reason) {
              if (!$loader.length) return;
              if ($loader.hasClass("is-visible")) return;

              loaderVisibleSince = Date.now();
              $loader.removeClass("hidden").addClass("is-visible").attr("aria-hidden", "false");

              clearTimeout(loaderMaxHideTimer);
              loaderMaxHideTimer = setTimeout(function () {
                hideLoader("timeout");
              }, 15000);
            }

            function scheduleShowLoader(reason) {
              if (!$loader.length) return;

              clearTimeout(loaderShowTimer);
              loaderShowTimer = setTimeout(function () {
                showLoaderNow(reason || "delayed");
              }, loaderShowDelayMs);
            }

            function showLoader(reason) {
              scheduleShowLoader(reason || "manual");
            }

            function hideLoader(reason) {
              if (!$loader.length) return;

              clearTimeout(loaderShowTimer);
              clearTimeout(loaderHideTimer);

              if (!$loader.hasClass("is-visible")) {
                clearTimeout(loaderMaxHideTimer);
                return;
              }

              var elapsed = Date.now() - (loaderVisibleSince || 0);
              if (elapsed < loaderMinVisibleMs) {
                loaderHideTimer = setTimeout(function () {
                  hideLoader(reason || "min-visible");
                }, loaderMinVisibleMs - elapsed);
                return;
              }

              $loader.removeClass("is-visible").addClass("hidden").attr("aria-hidden", "true");
              clearTimeout(loaderMaxHideTimer);
            }

// Initial iframe load: delay the loader (no blink)
            if ($iframe.length) {
              scheduleShowLoader("initial");
              $iframe.off("load.lpLoader").on("load.lpLoader", function () {
                syncCurrentItemFromIframe();
                hideLoader("iframe load");
                setTimeout(setupVideoNextOverlay, 150);
              });
              setTimeout(setupVideoNextOverlay, 500);
            } else {
              console.warn("LP: iframe not found (#content_id / #content_id_blank).");
            }

            $(document).off("click.lpLoaderNav").on(
              "click.lpLoaderNav",
              "#toc_id a, #btn-menu-float a, #btn-menu-float button",
              function () {
                var $t = $(this);

                // Do NOT show loader for the menu toggle (open/close).
                if ($toggle.length && ($t.is($toggle) || $t.closest($toggle).length)) {
                  return;
                }

                // Only show loader when this looks like real navigation.
                var href = ($t.attr("href") || "");
                var onclickValue = ($t.attr("onclick") || "");

                var isKnownNavButton = $t.is("#scorm-next, #scorm-previous, #home-course");
                var isTocClick = $t.closest("#toc_id").length > 0;

                var isLpContentLink =
                  href.indexOf("lp_controller.php") !== -1 ||
                  href.indexOf("lp_view.php") !== -1 ||
                  href.indexOf("lp_content.php") !== -1 ||
                  onclickValue.indexOf("lp_controller.php") !== -1 ||
                  onclickValue.indexOf("lp_view.php") !== -1 ||
                  onclickValue.indexOf("lp_content.php") !== -1 ||
                  onclickValue.indexOf("content_name") !== -1;

                if (!isKnownNavButton && !isTocClick && !isLpContentLink) {
                  return;
                }

                hideVideoNextOverlay();

                // Delay loader so fast loads don't show anything.
                scheduleShowLoader("nav click");
                scheduleLpRuntimeDecorations();
              }
            );

            function lpNavigateToItem(target, label) {
              var isDirection = (target === "next" || target === "previous" || target === "first" || target === "last");
              var targetItemId = 0;

              showLoader("navigate " + label);
              var currentItemId = getCurrentItemIdSafe();

              // If target is numeric, validate it.
              if (!isDirection) {
                targetItemId = parseInt(target, 10);
                if (!Number.isFinite(targetItemId) || targetItemId <= 0) {
                  console.warn("LP NAV: invalid target item id for " + label + ":", target);
                  hideLoader("nav failed");
                  return false;
                }
              }

              // If direction, first resolve it from TOC order (best for Chamilo LP).
              if (isDirection && (target === "next" || target === "previous")) {
                var tocResolved = resolveDirectionToId(target, currentItemId);
                if (tocResolved > 0 && tocResolved !== currentItemId) {
                  targetItemId = tocResolved;
                }
              }

              // Prefer switch_item if runtime is ready (keeps SCORM/LP state).
              if (window.olms && typeof switch_item === "function" && Number(olms.lms_initialized) === 1) {
                console.info("LP NAV: switching item via runtime", {
                  currentItemId: currentItemId,
                  target: isDirection ? (targetItemId > 0 ? targetItemId : target) : targetItemId
                });

                try {
                  // If we resolved a numeric target, pass numeric. Otherwise pass direction.
                  switch_item(currentItemId || 0, isDirection ? (targetItemId > 0 ? targetItemId : target) : targetItemId);
                  if (!isDirection || targetItemId > 0) {
                    window.lpCurrentItemId = targetItemId;
                  }
                  scheduleLpRuntimeDecorations();
                  return true;
                } catch (e) {
                  console.warn("LP NAV: switch_item() failed, falling back to iframe src update.", e);
                }
              }

              // Fallback: resolve direction from runtime vars only if TOC resolution failed.
              if (isDirection && targetItemId <= 0 && window.olms) {
                try {
                  if (target === "next") targetItemId = parseInt(olms.lms_next_item, 10) || 0;
                  if (target === "previous") targetItemId = parseInt(olms.lms_previous_item, 10) || 0;
                } catch (e) {}
              }

              // Final fallback: update iframe src directly.
              if (targetItemId > 0) {
                var $i = getLpIframe();
                if ($i.length) {
                  var src = buildContentUrlForItem(targetItemId);
                  console.info("LP NAV: updating iframe src (fallback).", src);
                  $i.attr("src", src);
                  window.lpCurrentItemId = targetItemId;
                  scheduleLpRuntimeDecorations();
                  setTimeout(syncCollapsedIframeBoundary, 100);
                  setTimeout(syncCollapsedIframeBoundary, 400);
                  return true;
                }
              }

              hideLoader("nav failed");
              return false;
            }

            /* -----------------------------------------------------------
             * Deterministic bindings for Next/Previous (Chamilo LP safe)
             * ----------------------------------------------------------- */
            function bindPrimaryNavButtons() {
              var $prev = $("#scorm-previous");
              var $next = $("#scorm-next");

              function bind($el, direction, label) {
                if (!$el || !$el.length) return;

                // Tag for easier debugging
                $el.attr("data-lp-nav", direction);

                // Remove legacy inline handlers to prevent NaN or dead navigation.
                // We still keep behavior via lpNavigateToItem().
                $el.removeAttr("onclick").removeAttr("target");

                if ($el.is("a")) {
                  $el.attr("href", "#");
                }

                $el.off("click.lpNavPrimary").on("click.lpNavPrimary", function (e) {
                  e.preventDefault();
                  e.stopPropagation();
                  console.info("LP NAV: " + label + " clicked -> navigating", direction);
                  lpNavigateToItem(direction, label);
                  return false;
                });
              }

              if (!$prev.length || !$next.length) {
                console.warn("LP NAV: primary #scorm-previous/#scorm-next elements not found. Will rely on heuristic patching.");
              }

              bind($prev, "previous", "previous");
              bind($next, "next", "next");
            }

            function looksLikePrev(el) {
              var $el = $(el);
              var t = ($el.attr("title") || "").toLowerCase();
              var a = ($el.attr("aria-label") || "").toLowerCase();
              var h = ($el.html() || "").toLowerCase();
              var s = [t, a, h].join(" ");

              return (
                s.indexOf("previous") !== -1 ||
                s.indexOf("prev") !== -1 ||
                s.indexOf("anterior") !== -1 ||
                s.indexOf("mdi-chevron-left") !== -1 ||
                s.indexOf("mdi-arrow-left") !== -1
              );
            }

            function looksLikeNext(el) {
              var $el = $(el);
              var t = ($el.attr("title") || "").toLowerCase();
              var a = ($el.attr("aria-label") || "").toLowerCase();
              var h = ($el.html() || "").toLowerCase();
              var s = [t, a, h].join(" ");

              return (
                s.indexOf("next") !== -1 ||
                s.indexOf("siguiente") !== -1 ||
                s.indexOf("mdi-chevron-right") !== -1 ||
                s.indexOf("mdi-arrow-right") !== -1
              );
            }

            function patchNavArrowsWhenTocHidden() {
              if (tocHiddenSetting !== 1) return;

              // Prefer known IDs if present (most reliable)
              var $prevEl = $("#scorm-previous");
              var $nextEl = $("#scorm-next");

              // If not found, fallback to heuristics inside the floating menu
              if (!$prevEl.length || !$nextEl.length) {
                var $candidates = $menu
                  .find("a, button")
                  .not("#home-course")
                  .not("#lp-view-expand-toggle")
                  .not("[data-lp-menu='toggle']");

                $prevEl = $prevEl.length ? $prevEl : $();
                $nextEl = $nextEl.length ? $nextEl : $();

                $candidates.each(function () {
                  if (!$prevEl.length && looksLikePrev(this)) $prevEl = $(this);
                  if (!$nextEl.length && looksLikeNext(this)) $nextEl = $(this);
                });
              }

              function applyPatchDirection($el, direction, label) {
                if (!$el || !$el.length) {
                  console.warn("LP NAV: cannot patch " + label + " (element not found).");
                  return;
                }

                $el.removeAttr("onclick").removeAttr("target");
                if ($el.is("a")) {
                  $el.attr("href", "#");
                }

                $el.off("click.lpNav").on("click.lpNav", function (e) {
                  e.preventDefault();
                  e.stopPropagation();
                  console.info("LP NAV: " + label + " clicked -> navigating direction", direction);
                  lpNavigateToItem(direction, label);
                  return false;
                });
              }

              applyPatchDirection($prevEl, "previous", "previous");
              applyPatchDirection($nextEl, "next", "next");
            }

            // When TOC is hidden, keep LP content navigation inside the iframe named "content_name".
            if (tocHiddenSetting === 1) {
              $menu.find("a").each(function () {
                var url = resolveUrl(this);
                if (!url) return;

                // If it's LP content navigation, ensure it targets the content iframe.
                var isLpContent =
                  url.indexOf("lp_controller.php") !== -1 &&
                  url.indexOf("action=content") !== -1;

                if (!isLpContent) return;

                var $a = $(this);
                var target = ($a.attr("target") || "").toLowerCase();

                if (!target || target === "_self" || target === "_top") {
                  $a.attr("target", "content_name");
                }
              });
            }

            // Keep original hook (guarded)
            try {
              if (typeof checkCurrentItemPosition === "function") {
                checkCurrentItemPosition({{ lp_current_item_id_num }});
              } else {
                console.warn("LP: checkCurrentItemPosition() is not available.");
              }
            } catch (err) {
              console.warn("LP: checkCurrentItemPosition() failed:", err);
            }

              {% if disable_js_in_lp_view == 0 %}
            try {
              var allowedTypes = ["link", "sco"];
              if (window.olms && typeof olms.lms_item_type !== "undefined") {
                if ($.inArray(olms.lms_item_type, allowedTypes) === -1) {
                    {{ frame_ready }}
                }
              } else {
                console.warn("LP: olms is not ready; skipping frame_ready hook.");
              }
            } catch (err) {
              console.warn("LP: frame_ready hook failed:", err);
            }
              {% endif %}

            function patchNavArrowsWhenTocHiddenSafe() {
              if (tocHiddenSetting !== 1) return;

              try {
                patchNavArrowsWhenTocHidden();
              } catch (e) {
                console.warn("LP NAV: patchNavArrowsWhenTocHidden() failed:", e);
              }
            }

            // Bind primary next/prev always (safe for Chamilo LP + SCORM)
            bindPrimaryNavButtons();
            setTimeout(bindPrimaryNavButtons, 200);
            setTimeout(bindPrimaryNavButtons, 600);
            setTimeout(cleanupLtiEmbedMenu, 200);
            setTimeout(cleanupLtiEmbedMenu, 600);
            if (tocHiddenSetting === 1) {
              // Run immediately + retries (menu markup sometimes arrives late)
              patchNavArrowsWhenTocHiddenSafe();
              setTimeout(patchNavArrowsWhenTocHiddenSafe, 200);
              setTimeout(patchNavArrowsWhenTocHiddenSafe, 600);
            }

          });
        </script>
    {% endautoescape %}
{% endblock %}
